---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Data — Saving South Street">
  <section class="max-w-3xl">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900">Data &amp; Methodology</h1>
    <p class="mt-3 text-stone-700">
      Documentation of how the fieldwork was conducted, how parcels and businesses were classified, and what
      sources fed the analysis — plus a download link for the underlying spreadsheet so others can verify the
      findings or build on them.
    </p>
  </section>
</Layout>
