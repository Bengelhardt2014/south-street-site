  <script>
    import L from 'leaflet';

    // --- Corridor vacancy figures for the neighborhood card ---
    // Hard-coded from the timeline series (NOT recomputed from the parcels) so
    // they compare cleanly against the 1995 trough. Edit these to adjust the
    // numbers shown on the cards.
    const SOUTH_ST_VACANCY_1995 = 13.8;        // % vacant — 1995 trough
    const SOUTH_ST_VACANCY_CURRENT = 27.8;     // % vacant — 2026 corridor-wide observed

    const VACANCY_COLORS: Record<string, string> = {
      active: '#4a7c2e',
      under_renovation: '#e0b020',
      short_term: '#c8632c',
      long_term: '#8b1a1a',
      non_commercial: '#a8a29e',
    };

    const STREET_STYLES: Record<string, { color: string; weight: number }> = {
      south_street: { color: '#7B3F99', weight: 14 },
      east_passyunk: { color: '#E67E22', weight: 14 },
    };

    function escapeHtml(value: unknown): string {
      if (value === null || value === undefined) return '';
      return String(value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatPrice(v: unknown): string {
      const n = Number(v);
      if (!Number.isFinite(n)) return escapeHtml(v);
      if (n === 1) return '$1';
      return '$' + n.toLocaleString('en-US');
    }

    // Title-case OPA owner strings ("AXELROD MICHAEL TR" -> "Axelrod Michael TR").
    // Acronyms and Roman numerals are preserved uppercase. Words spelled out
    // (REVOCABLE / IRREVOCABLE / TRUST) are title-cased per the user's example.
    const OWNER_PRESERVE_UPPER = new Set([
      'TR', 'LLC', 'INC', 'LP', 'LTD', 'LTD.', 'CO', 'CO.',
      'JR', 'JR.', 'SR', 'SR.',
      'I', 'II', 'III', 'IV', 'V', 'VI', 'VII', 'VIII', 'IX', 'X',
    ]);
    function titleCaseOwner(s: string): string {
      // Split keeping delimiters (whitespace, /, comma, hyphen) so we can
      // recombine them as-is.
      return s.split(/(\s+|\/|,|-)/g).map((tok) => {
        if (/^\s+$/.test(tok) || /^[\/,-]$/.test(tok)) return tok;
        const upper = tok.toUpperCase();
        if (OWNER_PRESERVE_UPPER.has(upper)) return upper;
        if (tok.length === 1) return upper;   // single-letter initial -> uppercase
        return tok.charAt(0).toUpperCase() + tok.slice(1).toLowerCase();
      }).join('');
    }

    type ParcelProps = {
      id: number;
      address: string | null;
      corridor: string | null;
      vacancy_state: string;
      vacant: string | null;
      vacancy_type: string | null;
      business_category: string | null;
      business_segment: string | null;
      operator_type: string | null;
      outdoor_footprint: string | null;
      cultural_tenant: string | null;
      cultural_status: string | null;
      year_built: number | string | null;
      zone_type: string | null;
      building_footprint: number | null;
      building_height: number | null;
      open_violations: number | null;
      last_sale_year: number | null;
      last_sale_price: number | string | null;
      owner: string | null;
      opa_property_use: string | null;
      out_of_area_owner: string | null;
      corporate_owner: string | null;
      // Augmented fields (Day 3, Phase 1)
      block_number: number | null;
      years_since_last_sale: number | null;
      lot_area: number | null;
      frontage: number | null;
      storefront_condition: number | null;
      structural_condition: number | null;
      consumer_price_level: number | null;
      peak_activation_period: number | null;
      mailing_city_state: string | null;
      last_sale_date: string | null;
    };

    // -------------------- Business mix filter options --------------------
    // 4 commercial vacancy states. The 5th internal value 'non_commercial'
    // (135 residential/civic parcels) is not filterable — that layer is
    // zoom-controlled (visible at zoom >= 18) and treated as background context.
    const VACANCY_OPTIONS: { value: string; label: string; color: string }[] = [
      { value: 'active',           label: 'Occupied',             color: '#4a7c2e' },
      { value: 'short_term',       label: 'Short-term turnover',  color: '#c8632c' },
      { value: 'under_renovation', label: 'Under renovation',     color: '#e0b020' },
      { value: 'long_term',        label: 'Long-term vacant',     color: '#8b1a1a' },
    ];

    const PEAK_OPTIONS: { value: number; label: string }[] = [
      { value: 1, label: 'Morning' },
      { value: 2, label: 'Midday' },
      { value: 3, label: 'Afternoon' },
      { value: 4, label: 'Evening' },
      { value: 5, label: 'Late night' },
    ];

    const OPERATOR_OPTIONS: string[] = [
      'Independent', 'Metro-only Chain', 'Regional Chain', 'National Chain',
    ];

    const PRICE_OPTIONS: { value: number; label: string }[] = [
      { value: 1, label: '$' },
      { value: 2, label: '$$' },
      { value: 3, label: '$$$' },
      { value: 4, label: '$$$$' },
    ];

    // -------------------- Building mix filter options --------------------
    const OWNERSHIP_OPTIONS: { key: string; label: string; count: number }[] = [
      { key: 'local',       label: 'Local owner',       count: 341 },
      { key: 'out_of_area', label: 'Out-of-area owner', count: 170 },
      { key: 'dollar_sale', label: '$1 sale',           count: 170 },
    ];

    const ZONE_OPTIONS: { value: string; count: number }[] = [
      { value: 'CMX-1',   count: 23 },
      { value: 'CMX-2',   count: 53 },
      { value: 'CMX-2.5', count: 270 },
      { value: 'CMX-3',   count: 95 },
      { value: 'RM-1',    count: 25 },
      { value: 'RSA-5',   count: 50 },
      { value: 'CA-1',    count: 2 },
      { value: 'SPPOA',   count: 1 },
    ];

    const YEARS_SINCE_SALE_FULL = { min: 0, max: 110 };
    const BUILDING_HEIGHT_FULL  = { min: 0, max: 65 };

    // Slider config table — generalized so updateRangeSliderUI and the input
    // handler can dispatch by data-range-group id.
    type SliderConfig = {
      stateKey: 'yearsSinceSale' | 'buildingHeight';
      full: { min: number; max: number };
      formatLabel: (v: number) => string;
    };
    const SLIDER_CONFIGS: Record<string, SliderConfig> = {
      'years-since-sale': {
        stateKey: 'yearsSinceSale',
        full: YEARS_SINCE_SALE_FULL,
        formatLabel: (v) => `${v} years`,
      },
      'building-height': {
        stateKey: 'buildingHeight',
        full: BUILDING_HEIGHT_FULL,
        formatLabel: (v) => `${v} ft`,
      },
    };

    // Non-commercial zones — when any of these are checked in the Zone filter,
    // the non-commercial layer becomes visible regardless of zoom.
    const NON_COMMERCIAL_ZONES = new Set<string>(['RM-1', 'RSA-5', 'CA-1', 'SPPOA']);

    // Segments excluded from the drill-down UI:
    //   "Vacant" — redundant with vacancy_state filter
    //   "Other" — 2-parcel catchall, not meaningful as a filter dimension
    const EXCLUDED_SEGMENTS = new Set(['Vacant', 'Other']);

    // -------------------- Filter state store --------------------
    type CorridorChoice = 'all' | 'south-street' | 'east-passyunk';

    type FilterState = {
      corridor: CorridorChoice;    // single-select; default 'all'
      vacancy: Set<string>;
      category: Set<string>;       // selected business_category values (segment is implicit)
      operator: Set<string>;
      peak: Set<number>;
      price: Set<number>;          // consumer_price_level values 1..4
      outdoorOnly: boolean;
      culturalLens: boolean;       // override: lens visualization overrides matchesAll
      blockFilter: { corridor: string | null; block_number: number | null };
      activeMetric: MetricKey;     // ribbon's active metric; drives metric-implied filter when block is selected
      // Building mix
      ownership: Set<string>;      // 'local' / 'out_of_area' / 'dollar_sale'; OR-internal
      yearsSinceSale: { min: number; max: number };  // range slider 0..110
      buildingHeight: { min: number; max: number };  // range slider 0..65 (ft)
      zone: Set<string>;           // zone_type values e.g. 'CMX-2.5'
    };

    let allCategories: string[] = [];       // populated after parcels load
    let segmentMap: Map<string, string[]> = new Map();
    let categoryCount: Record<string, number> = {};
    let segmentCount: Record<string, number> = {};
    let vacancyCount: Record<string, number> = {};
    let peakCount: Record<number, number> = {};
    let operatorCount: Record<string, number> = {};
    let priceCount: Record<number, number> = {};
    let zoneCount: Record<string, number> = {};
    let ownershipCount: Record<string, number> = { local: 0, out_of_area: 0, dollar_sale: 0 };

    // ADDITIVE paradigm: every filter group starts empty (nothing selected =
    // group inactive = every parcel passes). User clicks to narrow.
    const filterState: FilterState = {
      corridor: 'all',
      vacancy: new Set(),
      category: new Set(),
      operator: new Set(),
      peak: new Set(),
      price: new Set(),
      outdoorOnly: false,
      culturalLens: false,
      blockFilter: { corridor: null, block_number: null },
      activeMetric: 'vacancy_rate',
      ownership: new Set(),
      yearsSinceSale: { min: 0, max: 110 },
      buildingHeight: { min: 0, max: 65 },
      zone: new Set(),
    };

    const subscribers = new Set<() => void>();

    function subscribe(fn: () => void): () => void {
      subscribers.add(fn);
      return () => subscribers.delete(fn);
    }

    function setFilterState(updater: (s: FilterState) => void): void {
      updater(filterState);
      subscribers.forEach((fn) => fn());
    }

    // -------------------- Filter contract helpers --------------------
    // ADDITIVE (discovery) paradigm: a filter group is *inactive* when
    // nothing is selected (default). In that case every parcel passes,
    // including nulls. Once the user selects any option, the group becomes
    // active: only parcels whose value is in the selected set pass; nulls fail.
    // Range sliders follow the same idea — inactive at full extent.

    function passesFilter<T>(value: T | null, selectedSet: Set<T>): boolean {
      if (selectedSet.size === 0) return true;
      if (value === null) return false;
      return selectedSet.has(value);
    }

    function passesRange(
      value: number | null,
      range: { min: number; max: number },
      fullRange: { min: number; max: number },
    ): boolean {
      const isActive = range.min > fullRange.min || range.max < fullRange.max;
      if (!isActive) return true;
      if (value === null) return false;
      return value >= range.min && value <= range.max;
    }

    // OR-internal helper for the Ownership pattern group: ANY selected
    // predicate passing is enough.
    function passesOwnership(parcel: ParcelProps, ownershipSet: Set<string>): boolean {
      if (ownershipSet.size === 0) return true;
      if (ownershipSet.has('local') && parcel.out_of_area_owner === 'No') return true;
      if (ownershipSet.has('out_of_area') && parcel.out_of_area_owner === 'Yes') return true;
      if (ownershipSet.has('dollar_sale') && Number(parcel.last_sale_price) === 1) return true;
      return false;
    }

    // -------------------- Metric-implied filter (block + ribbon metric) --------------------
    // When a block is selected, the active ribbon metric narrows the visible
    // parcels to the subset that contributed to that metric's numerator. This
    // runs AND with the sidebar filters, so a parcel must pass both.
    // No-op when no block is selected. Lens mode bypasses matchesAll entirely
    // so this never runs in lens mode.
    function passesMetricImpliedFilter(p: ParcelProps): boolean {
      const bf = filterState.blockFilter;
      if (bf.corridor === null || bf.block_number === null) return true;
      switch (filterState.activeMetric) {
        case 'vacancy_rate':
          return (
            p.vacancy_state === 'short_term' ||
            p.vacancy_state === 'under_renovation' ||
            p.vacancy_state === 'long_term'
          );
        case 'outdoor_rate':
          return p.outdoor_footprint === 'Yes';
        case 'quick_service_rate':
          return (p.business_category || '').indexOf('Quick Service') !== -1;
        case 'nuisance_count':
          return p.business_category !== null && NUISANCE_CATEGORIES.has(p.business_category);
        case 'local_chain_count':
          return p.operator_type !== null && LOCAL_CHAIN_OPERATORS.has(p.operator_type);
      }
      return true;
    }

    // -------------------- matchesAll --------------------
    function matchesAll(p: ParcelProps): boolean {
      // Corridor — single-select, fast short-circuit.
      if (filterState.corridor !== 'all') {
        const expected = filterState.corridor === 'south-street' ? 'South Street' : 'East Passyunk';
        if (p.corridor !== expected) return false;
      }
      // Block filter — when set, parcel must match both corridor and block.
      const bf = filterState.blockFilter;
      if (bf.corridor !== null && bf.block_number !== null) {
        if (p.corridor !== bf.corridor || p.block_number !== bf.block_number) return false;
      }
      // Metric-implied filter — only when block is selected.
      if (!passesMetricImpliedFilter(p)) return false;
      // Business mix groups: inactive (empty Set) -> passes everything (incl. nulls).
      // Active (any selection) -> only matching values pass; nulls fail.
      if (!passesFilter(p.vacancy_state,           filterState.vacancy))  return false;
      if (!passesFilter(p.business_category,       filterState.category)) return false;
      if (!passesFilter(p.operator_type,           filterState.operator)) return false;
      if (!passesFilter(p.peak_activation_period,  filterState.peak))     return false;
      if (!passesFilter(p.consumer_price_level,    filterState.price))    return false;
      if (filterState.outdoorOnly && p.outdoor_footprint !== 'Yes')       return false;
      // Building mix groups (AND across groups; ownership is OR-internal)
      if (!passesOwnership(p, filterState.ownership))                                return false;
      if (!passesRange(p.years_since_last_sale, filterState.yearsSinceSale, YEARS_SINCE_SALE_FULL)) return false;
      if (!passesRange(p.building_height, filterState.buildingHeight, BUILDING_HEIGHT_FULL))       return false;
      if (!passesFilter(p.zone_type, filterState.zone))                              return false;
      return true;
    }

    // -------------------- Section dirty-count helpers --------------------
    // A group is dirty when at least one option is selected (or the toggle is on).
    function businessMixDirtyCount(): number {
      let n = 0;
      if (filterState.vacancy.size  > 0) n++;
      if (filterState.category.size > 0) n++;
      if (filterState.operator.size > 0) n++;
      if (filterState.peak.size     > 0) n++;
      if (filterState.price.size    > 0) n++;
      if (filterState.outdoorOnly)       n++;
      if (filterState.culturalLens)      n++;
      return n;
    }
    const BUSINESS_MIX_GROUP_COUNT = 7;

    function buildingMixDirtyCount(): number {
      let n = 0;
      if (filterState.ownership.size > 0) n++;
      if (
        filterState.yearsSinceSale.min > YEARS_SINCE_SALE_FULL.min ||
        filterState.yearsSinceSale.max < YEARS_SINCE_SALE_FULL.max
      ) {
        n++;
      }
      if (filterState.zone.size > 0) n++;
      if (
        filterState.buildingHeight.min > BUILDING_HEIGHT_FULL.min ||
        filterState.buildingHeight.max < BUILDING_HEIGHT_FULL.max
      ) {
        n++;
      }
      return n;
    }
    const BUILDING_MIX_GROUP_COUNT = 4;

    function resetBusinessMix(): void {
      filterState.vacancy = new Set();
      filterState.category = new Set();
      filterState.operator = new Set();
      filterState.peak = new Set();
      filterState.price = new Set();
      filterState.outdoorOnly = false;
      filterState.culturalLens = false;
      resyncBusinessMixUI();
    }

    function resetBuildingMix(): void {
      filterState.ownership = new Set();
      filterState.yearsSinceSale = { min: 0, max: 110 };
      filterState.buildingHeight = { min: 0, max: 65 };
      filterState.zone = new Set();
      // Reset chip aria-pressed for Building mix
      document
        .querySelectorAll<HTMLButtonElement>('[data-section="building-mix"] .chip')
        .forEach((b) => b.setAttribute('aria-pressed', 'false'));
      // Reset slider input values + UI for both sliders
      updateRangeSliderUI('years-since-sale');
      updateRangeSliderUI('building-height');
    }

    // -------------------- Segment structure (corridor-independent) --------------------
    // Builds segmentMap + allCategories once from the full dataset; segment ordering
    // is fixed by global counts so it stays stable when corridor scope changes.
    function buildSegmentMap(parcelsGj: GeoJSON.FeatureCollection): void {
      const segCats = new Map<string, Set<string>>();
      const segGlobal: Record<string, number> = {};
      for (const f of parcelsGj.features) {
        const p = f.properties as ParcelProps;
        const seg = p.business_segment;
        const cat = p.business_category;
        if (!seg || EXCLUDED_SEGMENTS.has(seg)) continue;
        segGlobal[seg] = (segGlobal[seg] || 0) + 1;
        if (cat) {
          if (!segCats.has(seg)) segCats.set(seg, new Set());
          segCats.get(seg)!.add(cat);
        }
      }
      const sortedSegs = Array.from(segCats.keys()).sort(
        (a, b) => (segGlobal[b] || 0) - (segGlobal[a] || 0),
      );
      segmentMap = new Map();
      for (const s of sortedSegs) {
        const cats = Array.from(segCats.get(s)!).sort();
        segmentMap.set(s, cats);
      }
      allCategories = sortedSegs.flatMap((s) => segmentMap.get(s) || []);
    }

    // -------------------- Chip count tabulation (scope-aware) --------------------
    // Re-runs on every state change. Each chip count reflects:
    //   - parcels matching the chip's predicate
    //   - within the current corridor scope
    //   - within the current visible-layer scope (commercial+vacant always;
    //     non-commercial included when the non-commercial layer is visible)
    // Filters in OTHER chip groups do not affect a group's counts.
    function recomputeChipCounts(): void {
      if (!parcelsGjRef) return;
      const corridor = filterState.corridor;
      const includeNc = shouldShowNonCommercialLayer();

      const segC: Record<string, number> = {};
      const catC: Record<string, number> = {};
      const vacC: Record<string, number> = {};
      const peakC: Record<number, number> = {};
      const opC: Record<string, number> = {};
      const priceC: Record<number, number> = {};
      const zoneC: Record<string, number> = {};
      const ownC: Record<string, number> = { local: 0, out_of_area: 0, dollar_sale: 0 };

      for (const f of parcelsGjRef.features) {
        const p = f.properties as ParcelProps;
        if (p.vacancy_state === 'non_commercial' && !includeNc) continue;
        if (corridor === 'south-street'  && p.corridor !== 'South Street')  continue;
        if (corridor === 'east-passyunk' && p.corridor !== 'East Passyunk') continue;

        // Business mix counts (non-commercial parcels mostly skip via null/sentinel checks)
        if (p.vacancy_state !== 'non_commercial') {
          vacC[p.vacancy_state] = (vacC[p.vacancy_state] || 0) + 1;
        }
        if (typeof p.peak_activation_period === 'number') {
          peakC[p.peak_activation_period] = (peakC[p.peak_activation_period] || 0) + 1;
        }
        if (typeof p.consumer_price_level === 'number') {
          priceC[p.consumer_price_level] = (priceC[p.consumer_price_level] || 0) + 1;
        }
        if (p.operator_type && p.operator_type !== 'Vacant') {
          opC[p.operator_type] = (opC[p.operator_type] || 0) + 1;
        }
        const seg = p.business_segment;
        const cat = p.business_category;
        if (seg && !EXCLUDED_SEGMENTS.has(seg)) {
          segC[seg] = (segC[seg] || 0) + 1;
          if (cat) catC[cat] = (catC[cat] || 0) + 1;
        }

        // Building mix counts
        if (p.zone_type) zoneC[p.zone_type] = (zoneC[p.zone_type] || 0) + 1;
        if (p.out_of_area_owner === 'No') ownC.local++;
        if (p.out_of_area_owner === 'Yes') ownC.out_of_area++;
        const lsp = p.last_sale_price;
        if (lsp !== null && lsp !== undefined) {
          const n = Number(lsp);
          if (Number.isFinite(n) && n === 1) ownC.dollar_sale++;
        }
      }

      // Non-commercial zone chips (RM-1, RSA-5, CA-1, SPPOA) reflect the full
      // corridor-scoped universe regardless of layer visibility. The semantic
      // is "this count is what becomes visible after the click." Without this
      // second pass, those chips would read (0) when the layer is hidden,
      // making them appear useless. Commercial zones (CMX-*) and all other
      // chip groups keep the visible-scope semantic.
      if (!includeNc) {
        for (const f of parcelsGjRef.features) {
          const p = f.properties as ParcelProps;
          if (p.vacancy_state !== 'non_commercial') continue;
          if (corridor === 'south-street'  && p.corridor !== 'South Street')  continue;
          if (corridor === 'east-passyunk' && p.corridor !== 'East Passyunk') continue;
          if (p.zone_type && NON_COMMERCIAL_ZONES.has(p.zone_type)) {
            zoneC[p.zone_type] = (zoneC[p.zone_type] || 0) + 1;
          }
        }
      }

      segmentCount = segC;
      categoryCount = catC;
      vacancyCount = vacC;
      peakCount = peakC;
      operatorCount = opC;
      priceCount = priceC;
      zoneCount = zoneC;
      ownershipCount = ownC;
    }

    // -------------------- Non-commercial layer visibility logic --------------------
    function shouldShowNonCommercialLayer(): boolean {
      if (!mapRef) return false;
      if (mapRef.getZoom() >= NON_COMMERCIAL_MIN_ZOOM) return true;
      for (const z of NON_COMMERCIAL_ZONES) {
        if (filterState.zone.has(z)) return true;
      }
      return false;
    }
    const NON_COMMERCIAL_MIN_ZOOM = 18;

    // -------------------- Sidebar count-span DOM updater --------------------
    function updateAllCountSpans(): void {
      document.querySelectorAll<HTMLElement>('[data-count-vacancy]').forEach((el) => {
        const v = el.dataset.countVacancy!;
        el.textContent = `(${vacancyCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-segment]').forEach((el) => {
        const v = el.dataset.countSegment!;
        el.textContent = `(${segmentCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-category]').forEach((el) => {
        const v = el.dataset.countCategory!;
        el.textContent = `(${categoryCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-operator]').forEach((el) => {
        const v = el.dataset.countOperator!;
        el.textContent = `(${operatorCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-peak]').forEach((el) => {
        const v = Number(el.dataset.countPeak);
        el.textContent = `(${peakCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-price]').forEach((el) => {
        const v = Number(el.dataset.countPrice);
        el.textContent = `(${priceCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-ownership]').forEach((el) => {
        const v = el.dataset.countOwnership!;
        el.textContent = `(${ownershipCount[v] || 0})`;
      });
      document.querySelectorAll<HTMLElement>('[data-count-zone]').forEach((el) => {
        const v = el.dataset.countZone!;
        el.textContent = `(${zoneCount[v] || 0})`;
      });
    }

    // -------------------- Sidebar HTML rendering --------------------
    function renderBusinessMixUI(): void {
      // Vacancy checkboxes (default: unchecked)
      const vacWrap = document.querySelector('.filter-vacancy-list') as HTMLElement | null;
      if (vacWrap) {
        vacWrap.innerHTML = VACANCY_OPTIONS.map((o) => `
          <label class="filter-check">
            <input type="checkbox" class="filter-vacancy" data-value="${o.value}" />
            <span class="filter-swatch" style="background:${o.color}"></span>
            <span class="filter-check-label">${escapeHtml(o.label)} <span class="count" data-count-vacancy="${o.value}">(${vacancyCount[o.value] || 0})</span></span>
          </label>
        `).join('');
      }

      // Segment drill-down (default: unchecked, collapsed)
      const segWrap = document.getElementById('segment-list');
      if (segWrap) {
        const parts: string[] = [];
        for (const [seg, cats] of segmentMap) {
          parts.push(`
            <div class="segment" data-segment="${escapeHtml(seg)}">
              <div class="segment-header">
                <button type="button" class="segment-chevron" aria-expanded="false" aria-label="Toggle ${escapeHtml(seg)}">▶</button>
                <input type="checkbox" class="segment-parent" data-segment="${escapeHtml(seg)}" />
                <button type="button" class="segment-label">${escapeHtml(seg)} <span class="count" data-count-segment="${escapeHtml(seg)}">(${segmentCount[seg] || 0})</span></button>
              </div>
              <div class="segment-children" hidden>
                ${cats.map((c) => `
                  <label class="filter-check">
                    <input type="checkbox" class="filter-category" data-segment="${escapeHtml(seg)}" data-category="${escapeHtml(c)}" />
                    <span class="filter-check-label">${escapeHtml(c)} <span class="count" data-count-category="${escapeHtml(c)}">(${categoryCount[c] || 0})</span></span>
                  </label>
                `).join('')}
              </div>
            </div>
          `);
        }
        segWrap.innerHTML = parts.join('');
      }

      // Operator chips (default: unpressed)
      const opWrap = document.querySelector('.chip-row[data-chip-group="operator"]') as HTMLElement | null;
      if (opWrap) {
        opWrap.innerHTML = OPERATOR_OPTIONS.map((o) => `
          <button type="button" class="chip" data-value="${escapeHtml(o)}" aria-pressed="false">${escapeHtml(o)} <span class="count" data-count-operator="${escapeHtml(o)}">(${operatorCount[o] || 0})</span></button>
        `).join('');
      }

      // Peak chips (default: unpressed)
      const peakWrap = document.querySelector('.chip-row[data-chip-group="peak"]') as HTMLElement | null;
      if (peakWrap) {
        peakWrap.innerHTML = PEAK_OPTIONS.map((o) => `
          <button type="button" class="chip" data-value="${o.value}" aria-pressed="false">${escapeHtml(o.label)} <span class="count" data-count-peak="${o.value}">(${peakCount[o.value] || 0})</span></button>
        `).join('');
      }

      // Consumer price level chips (default: unpressed)
      const priceWrap = document.querySelector('.chip-row[data-chip-group="price"]') as HTMLElement | null;
      if (priceWrap) {
        priceWrap.innerHTML = PRICE_OPTIONS.map((o) => `
          <button type="button" class="chip" data-value="${o.value}" aria-pressed="false">${escapeHtml(o.label)} <span class="count" data-count-price="${o.value}">(${priceCount[o.value] || 0})</span></button>
        `).join('');
      }
    }

    // -------------------- Building mix UI --------------------
    function renderRangeSlider(groupId: string, labelMinAria: string, labelMaxAria: string): void {
      const cfg = SLIDER_CONFIGS[groupId];
      if (!cfg) return;
      const root = document.querySelector<HTMLElement>(
        `.range-slider[data-range-group="${groupId}"]`,
      );
      if (!root) return;
      root.innerHTML = `
        <div class="range-slider-labels">
          <span class="range-slider-value range-slider-value-min">${escapeHtml(cfg.formatLabel(cfg.full.min))}</span>
          <span class="range-slider-value range-slider-value-max">${escapeHtml(cfg.formatLabel(cfg.full.max))}</span>
        </div>
        <div class="range-slider-track">
          <div class="range-slider-fill"></div>
          <input type="range" class="range-slider-handle range-slider-handle-min" min="${cfg.full.min}" max="${cfg.full.max}" step="1" value="${cfg.full.min}" aria-label="${escapeHtml(labelMinAria)}" />
          <input type="range" class="range-slider-handle range-slider-handle-max" min="${cfg.full.min}" max="${cfg.full.max}" step="1" value="${cfg.full.max}" aria-label="${escapeHtml(labelMaxAria)}" />
        </div>
      `;
      updateRangeSliderUI(groupId);
    }

    function renderBuildingMixUI(): void {
      // Render order mirrors the section's visual order: Zone, Ownership,
      // Building height, Years since last sale.

      // Zone chips
      const zoneWrap = document.querySelector<HTMLElement>(
        '.chip-row[data-chip-group="zone"]',
      );
      if (zoneWrap) {
        zoneWrap.innerHTML = ZONE_OPTIONS.map(
          (z) => `
          <button type="button" class="chip" data-value="${escapeHtml(z.value)}" aria-pressed="false">${escapeHtml(z.value)} <span class="count" data-count-zone="${escapeHtml(z.value)}">(${zoneCount[z.value] || 0})</span></button>
        `,
        ).join('');
      }

      // Ownership chips — initial counts filled by recomputeChipCounts + updateAllCountSpans
      const ownWrap = document.querySelector<HTMLElement>(
        '.chip-row[data-chip-group="ownership"]',
      );
      if (ownWrap) {
        ownWrap.innerHTML = OWNERSHIP_OPTIONS.map(
          (o) => `
          <button type="button" class="chip" data-value="${o.key}" aria-pressed="false">${escapeHtml(o.label)} <span class="count" data-count-ownership="${o.key}">(${ownershipCount[o.key] || 0})</span></button>
        `,
        ).join('');
      }

      // Range sliders — markup + initial sync (building height first, then years)
      renderRangeSlider('building-height', 'Minimum building height', 'Maximum building height');
      renderRangeSlider('years-since-sale', 'Minimum years since last sale', 'Maximum years since last sale');
    }

    // Keeps a slider's two inputs, fill bar, and label text in sync with
    // filterState[stateKey]. Generalized over groupId via SLIDER_CONFIGS.
    function updateRangeSliderUI(groupId: string): void {
      const cfg = SLIDER_CONFIGS[groupId];
      if (!cfg) return;
      const root = document.querySelector<HTMLElement>(
        `.range-slider[data-range-group="${groupId}"]`,
      );
      if (!root) return;
      const minInput = root.querySelector<HTMLInputElement>('.range-slider-handle-min');
      const maxInput = root.querySelector<HTMLInputElement>('.range-slider-handle-max');
      const fill = root.querySelector<HTMLElement>('.range-slider-fill');
      const minLabel = root.querySelector<HTMLElement>('.range-slider-value-min');
      const maxLabel = root.querySelector<HTMLElement>('.range-slider-value-max');
      if (!minInput || !maxInput || !fill || !minLabel || !maxLabel) return;
      const state = filterState[cfg.stateKey];
      const { min, max } = state;
      if (minInput.value !== String(min)) minInput.value = String(min);
      if (maxInput.value !== String(max)) maxInput.value = String(max);
      const range = cfg.full.max - cfg.full.min;
      const leftPct = ((min - cfg.full.min) / range) * 100;
      const rightPct = ((cfg.full.max - max) / range) * 100;
      fill.style.left = `${leftPct}%`;
      fill.style.right = `${rightPct}%`;
      minLabel.textContent = cfg.formatLabel(min);
      maxLabel.textContent = cfg.formatLabel(max);
    }

    function resyncBusinessMixUI(): void {
      // Vacancy
      document.querySelectorAll<HTMLInputElement>('.filter-vacancy').forEach((cb) => {
        cb.checked = filterState.vacancy.has(cb.dataset.value || '');
      });
      // Categories + parent
      document.querySelectorAll<HTMLInputElement>('.filter-category').forEach((cb) => {
        cb.checked = filterState.category.has(cb.dataset.category || '');
      });
      for (const seg of segmentMap.keys()) syncSegmentParent(seg);
      // Operator chips
      document.querySelectorAll<HTMLButtonElement>('.chip-row[data-chip-group="operator"] .chip').forEach((b) => {
        const v = b.dataset.value || '';
        b.setAttribute('aria-pressed', filterState.operator.has(v) ? 'true' : 'false');
      });
      // Peak chips
      document.querySelectorAll<HTMLButtonElement>('.chip-row[data-chip-group="peak"] .chip').forEach((b) => {
        const v = Number(b.dataset.value);
        b.setAttribute('aria-pressed', filterState.peak.has(v) ? 'true' : 'false');
      });
      // Price chips
      document.querySelectorAll<HTMLButtonElement>('.chip-row[data-chip-group="price"] .chip').forEach((b) => {
        const v = Number(b.dataset.value);
        b.setAttribute('aria-pressed', filterState.price.has(v) ? 'true' : 'false');
      });
      // Outdoor
      const outdoor = document.getElementById('filter-outdoor') as HTMLInputElement | null;
      if (outdoor) outdoor.checked = filterState.outdoorOnly;
      // Lens
      const lens = document.getElementById('filter-lens') as HTMLInputElement | null;
      if (lens) lens.checked = filterState.culturalLens;
    }

    function syncSegmentParent(seg: string): void {
      const parent = document.querySelector<HTMLInputElement>(
        `.segment-parent[data-segment="${CSS.escape(seg)}"]`,
      );
      if (!parent) return;
      const cats = segmentMap.get(seg) || [];
      const sel = cats.filter((c) => filterState.category.has(c)).length;
      if (sel === 0) {
        parent.checked = false;
        parent.indeterminate = false;
      } else if (sel === cats.length) {
        parent.checked = true;
        parent.indeterminate = false;
      } else {
        parent.checked = false;
        parent.indeterminate = true;
      }
    }

    function toggleSegmentExpand(segEl: Element): void {
      const children = segEl.querySelector('.segment-children') as HTMLElement | null;
      const chevron = segEl.querySelector('.segment-chevron');
      if (!children || !chevron) return;
      const collapsed = children.hasAttribute('hidden');
      if (collapsed) {
        children.removeAttribute('hidden');
        chevron.setAttribute('aria-expanded', 'true');
      } else {
        children.setAttribute('hidden', '');
        chevron.setAttribute('aria-expanded', 'false');
      }
    }

    function updateSidebarChrome(): void {
