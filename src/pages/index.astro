    /* Corridor segmented control — 3 pill buttons spanning sidebar width */
    .corridor-segmented {
      display: flex;
      gap: 4px;
    }
    .corridor-segment {
      flex: 1;
      padding: 6px 6px;
      border-radius: 6px;
