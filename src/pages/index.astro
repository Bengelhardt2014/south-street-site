---
import Layout from '../layouts/Layout.astro';

// Bulbs strung along the bottom edge of the letter board (slow chase).
const bulbs = Array.from({ length: 28 });

// The three "now playing" problems — each links to the map for now.
const problems = ['Governance Gridlock', 'Dormant Ownership', 'Declining Demand'];
---

<Layout title="Saving South Street" fullBleed>
  <section class="cover">
    <div class="stage">
      <div class="marquee">
        <!-- Red Philadelphia globe lamppost, standing at the left edge -->
        <svg
          class="lamppost"
          viewBox="0 0 60 360"
          aria-hidden="true"
          focusable="false"
        >
          <circle class="lamp-glow" cx="30" cy="42" r="28" fill="#ffd98a" />
          <path d="M30 6 l5 13 h-10 z" fill="#8e2018" />
          <circle cx="30" cy="42" r="17" fill="#fff6e0" stroke="#e7c483" stroke-width="1" />
          <rect x="21" y="57" width="18" height="7" rx="2.5" fill="#9e271d" />
          <path d="M27 64 L25.5 318 H34.5 L33 64 Z" fill="#b02a1f" />
          <rect x="23.5" y="120" width="13" height="6" rx="1" fill="#8a1e16" />
          <rect x="23" y="214" width="14" height="6" rx="1" fill="#8a1e16" />
          <path d="M17 318 H43 L47 346 H13 Z" fill="#9e271d" />
          <rect x="9" y="346" width="42" height="11" rx="2.5" fill="#7e1c15" />
        </svg>

        <!-- 1. Black header plate (the venue brand) -->
        <div class="plate">
          <div class="badge">SSS</div>
          <div class="brand">Saving South Street</div>
          <p class="subtitle">A four-part strategy to restabilize a historic cultural corridor</p>
          <p class="credit">Brandon K. Engelhardt &middot; MS Urban Strategy &middot; Drexel 2026</p>
        </div>

        <!-- 2. White changeable-letter board -->
        <div class="board">
          <div class="board-inner">
            <div class="kicker">Now Playing</div>
            <div class="board-lead">What's holding South Street back</div>
            <div class="rows">
              {problems.map((name) => (
                <a class="row" href="/map">
                  <span class="prob">{name}</span>
                  <span class="cue">see the map &rarr;</span>
                </a>
              ))}
            </div>
          </div>
          <!-- 3. Strung warm bulbs along the bottom edge -->
          <div class="bulbs" aria-hidden="true">
            {bulbs.map((_, i) => (
              <span class="bulb" style={`animation-delay:${(i * 0.11).toFixed(2)}s`}></span>
            ))}
          </div>
        </div>
      </div>

      <!-- 6. Ticket-style buttons -->
      <p class="ticket-kicker">Also showing</p>
      <div class="tickets">
        <a class="ticket" href="/map">Not enough density</a>
        <a class="ticket" href="/map">No outdoor space</a>
        <a class="ticket" href="/map">Too much nightlife</a>
        <a class="ticket" href="/map">Too much takeout</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .cover {
    position: relative;
    min-height: calc(100dvh - 58px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.5rem 3.5rem;
    background-color: #05070f;
    background-image:
      linear-gradient(rgba(4, 6, 14, 0.82), rgba(2, 3, 9, 0.93)),
      url('/images/tla-marquee.png');
    background-size: cover;
    background-position: center 35%;
    overflow: hidden;
  }
  /* Night vignette so the white board glows against the dark */
  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 42%,
      rgba(20, 28, 56, 0.25),
      rgba(2, 3, 9, 0.78) 78%
    );
    pointer-events: none;
  }

  .stage {
    position: relative;
    width: min(92vw, 740px);
    margin: 0 auto;
    text-align: center;
  }

  /* ---- Marquee wrapper (anchors the lamppost) ---- */
  .marquee {
    position: relative;
  }

  /* ---- Lamppost ---- */
  .lamppost {
    position: absolute;
    left: -52px;
    bottom: 4px;
    width: 60px;
    height: auto;
    filter: drop-shadow(0 0 6px rgba(0, 0, 0, 0.6));
    z-index: 3;
  }
  .lamp-glow {
    filter: blur(7px);
    transform-origin: center;
    animation: lampPulse 3.6s ease-in-out infinite;
  }
  @keyframes lampPulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.85; }
  }

  /* ---- 1. Header plate ---- */
  .plate {
    position: relative;
    z-index: 2;
    background: #07080c;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-bottom: none;
    border-radius: 10px 10px 0 0;
    padding: 1.3rem 1rem 1.15rem;
    box-shadow: 0 -2px 30px rgba(0, 0, 0, 0.5);
  }
  .badge {
    width: 62px;
    height: 62px;
    margin: 0 auto 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(245, 240, 230, 0.55);
    border-radius: 50%;
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    font-size: 1.24rem;
    letter-spacing: 0.12em;
    color: #f5f0e6;
    text-indent: 0.12em;
  }
  .brand {
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    text-indent: 0.32em;
    color: #f5f0e6;
    font-size: clamp(1.22rem, 4.9vw, 1.78rem);
    line-height: 1.1;
    -webkit-text-stroke: 0.5px currentColor;
  }
  .brand-sub {
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    text-indent: 0.26em;
    font-size: 0.6rem;
    color: rgba(214, 206, 190, 0.7);
  }

  /* ---- 2. Letter board ---- */
  .board {
    position: relative;
    z-index: 1;
    background: #0d0f14;            /* dark frame */
    border-radius: 0 0 10px 10px;
    padding: 11px 11px 28px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.7), 0 0 64px rgba(255, 224, 168, 0.08);
  }
  .board-inner {
    position: relative;
    background: #f6f4ee;            /* changeable-letter white */
    border-radius: 3px;
    padding: 1.7rem 2rem 1.8rem;
    overflow: hidden;
  }
  /* Faint horizontal track lines across the white */
  .board-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 40px,
      rgba(0, 0, 0, 0.07) 40px,
      rgba(0, 0, 0, 0.07) 41px
    );
    pointer-events: none;
  }
  .kicker {
    position: relative;
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    font-size: 0.79rem;
    font-weight: 700;
    color: #c01a1a;
  }
  .board-lead {
    position: relative;
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    color: #6b6459;
  }
  .rows {
    position: relative;
    margin-top: 1.3rem;
    text-align: left;
  }
  .row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.85rem;
    padding: 0.85rem 0;
    border-top: 1px dotted #b8b2a4;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .row:last-child {
    border-bottom: 1px dotted #b8b2a4;
  }
  .row:hover,
  .row:focus-visible {
    background-color: rgba(192, 26, 26, 0.05);
    outline: none;
  }
  .prob {
    font-family: 'Anton', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.55rem, 4.6vw, 2.4rem);
    line-height: 1;
    color: #14140f;
  }
  .cue {
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.68rem;
    font-weight: 700;
    color: #c01a1a;
    white-space: nowrap;
  }

  /* ---- 3. Bulb string ---- */
  .bulbs {
    position: absolute;
    left: 15px;
    right: 15px;
    bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .bulb {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ffcf73;
    box-shadow: 0 0 4px #ffbf57, 0 0 7px rgba(255, 157, 46, 0.7);
    animation: bulbChase 2.4s ease-in-out infinite;
  }
  @keyframes bulbChase {
    0%, 100% {
      opacity: 0.32;
      box-shadow: 0 0 2px rgba(255, 191, 87, 0.5);
    }
    50% {
      opacity: 1;
      box-shadow: 0 0 7px #ffcf73, 0 0 13px rgba(255, 157, 46, 0.85);
    }
  }

  /* ---- 5. Subtitle + credit ---- */
  .subtitle {
    margin: 0.9rem auto 0;
    max-width: 38rem;
    font-family: Georgia, 'Times New Roman', ui-serif, serif;
    font-style: italic;
    font-size: 1.24rem;
    line-height: 1.5;
    color: #e7e2d6;
  }
  .credit {
    margin-top: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.71rem;
    color: rgba(196, 189, 174, 0.65);
  }

  /* ---- 6. Ticket buttons ---- */
  .ticket-kicker {
    margin-top: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    font-size: 0.66rem;
    font-weight: 700;
    color: rgba(196, 189, 174, 0.7);
  }
  .tickets {
    margin-top: 0.7rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  .ticket {
    position: relative;
    background: #f3efe4;
    color: #1a1813;
    text-decoration: none;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.66rem 1.1rem;
    border-radius: 4px;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.45);
    transition: transform 0.12s ease, background-color 0.12s ease;
  }
  /* Perforated ticket notches on the left & right edges */
  .ticket::before,
  .ticket::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 8px;
    height: 8px;
    background: #05070f;
    border-radius: 50%;
    transform: translateY(-50%);
  }
  .ticket::before { left: -4px; }
  .ticket::after { right: -4px; }
  .ticket:hover,
  .ticket:focus-visible {
    background: #fff;
    transform: translateY(-1px);
    outline: none;
  }

  @media (max-width: 760px) {
    .lamppost { left: -26px; width: 52px; }
  }
  @media (max-width: 480px) {
    .lamppost { left: -6px; width: 44px; }
    .cue { display: none; }
  }

  /* Reduced-motion guard: freeze the chase & glow, leave everything lit */
  @media (prefers-reduced-motion: reduce) {
    .bulb {
      animation: none;
      opacity: 1;
      box-shadow: 0 0 7px #ffcf73, 0 0 13px rgba(255, 157, 46, 0.85);
    }
    .lamp-glow {
      animation: none;
      opacity: 0.75;
    }
    .ticket,
    .row { transition: none; }
  }
</style>
