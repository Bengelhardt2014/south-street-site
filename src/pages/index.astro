    /* Dual-handle range slider (Building mix → Years since last sale).
       Two overlaid <input type="range"> elements; the thumb on each handles
       its own drag while the input box itself is pointer-events: none, so the
       user can grab whichever thumb is closer. */
    .range-slider {
      padding: 0 4px;
    }
    .range-slider-labels {
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      color: #57534e;
