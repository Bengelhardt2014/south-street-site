---
import Layout from '../layouts/Layout.astro';

// Bulbs strung along the bottom edge of the letter board (slow chase).
const bulbs = Array.from({ length: 28 });

// The three "now playing" problems — each links to the map for now.
const problems = ['Governance Gridlock', 'Dormant Ownership', 'Declining Demand'];
---

<Layout title="Saving South Street" fullBleed>
  <section class="cover">
    <div class="stage">
      <div class="marquee">
        <!-- Red Philadelphia globe lamppost, standing at the left edge -->
        <svg
          class="lamppost"
          viewBox="0 0 60 486"
          aria-hidden="true"
          focusable="false"
        >
          <circle class="lamp-glow" cx="30" cy="42" r="28" fill="#ffd98a" />
          <path d="M30 6 l5 13 h-10 z" fill="#8e2018" />
          <circle cx="30" cy="42" r="17" fill="#fff6e0" stroke="#e7c483" stroke-width="1" />
          <rect x="21" y="57" width="18" height="7" rx="2.5" fill="#9e271d" />
          <path d="M27 64 L25.5 444 H34.5 L33 64 Z" fill="#b02a1f" />
          <rect x="23.5" y="120" width="13" height="6" rx="1" fill="#8a1e16" />
          <rect x="23" y="214" width="14" height="6" rx="1" fill="#8a1e16" />
          <path d="M17 444 H43 L47 472 H13 Z" fill="#9e271d" />
          <rect x="9" y="472" width="42" height="11" rx="2.5" fill="#7e1c15" />
        </svg>

        <!-- 1. Small framed marquee sign (the venue brand) -->
        <div class="plate">
          <div class="plate-head">
            <div class="badge">SSS</div>
            <div class="brand">Saving South Street</div>
          </div>
          <p class="sign-sub">South Street &middot; Philadelphia</p>
        </div>

        <!-- 2. White changeable-letter board — two-sided 3D flip card -->
        <div class="board">
          <!-- Only .flip (the two faces) rotates; the frame & bulbs stay put -->
          <div class="flip-frame">
            <div class="flip" data-flip>
              <!-- FRONT: the problems -->
              <div class="face face-front">
                <div class="face-content">
                  <div class="kicker">Now Playing</div>
                  <div class="board-lead">What's holding South Street back</div>
                  <div class="rows">
                    {problems.map((name) => (
                      <a class="row" href={name === 'Governance Gridlock' ? '/map?view=governance' : name === 'Dormant Ownership' ? '/map?view=ownership' : name === 'Declining Demand' ? '/map?view=demand' : '/map'}>
                        <span class="prob">{name}</span>
                        <span class="cue">see the map &rarr;</span>
                      </a>
                    ))}
                  </div>
                </div>
              </div>

              <!-- BACK: the policy "bill" -->
              <div class="face face-back">
                <div class="face-content bill">
                  <div class="kicker">The Main Event</div>
                  <a class="headliner" href="/analysis">Full Policy<span class="headliner-arrow" aria-hidden="true">&rarr;</span></a>
                  <a class="bill-summary-cta" href="/summary">See the summary <span aria-hidden="true">&rarr;</span></a>
                  <div class="bill-sub">The integrated four-part package.</div>
                  <div class="featuring-label">Featuring</div>
                  <div class="acts">
                    <a class="act" href="/analysis#proposal-1">Creative District &amp; Overlay</a>
                    <a class="act" href="/analysis#proposal-2">Revitalization Corporation</a>
                    <a class="act" href="/analysis#proposal-3">Upzone to CMX3</a>
                    <a class="act" href="/analysis#proposal-4">Pedestrian Plaza at 300</a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Flip carets mounted on the stable frame (these do NOT rotate) -->
          <button
            type="button"
            class="frame-caret frame-caret-right"
            data-flip-to-back
            aria-label="See the policy"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="9 5 16 12 9 19" />
            </svg>
          </button>
          <button
            type="button"
            class="frame-caret frame-caret-left"
            data-flip-to-front
            aria-label="Back to the problems"
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="15 5 8 12 15 19" />
            </svg>
          </button>

          <!-- 3. Strung warm bulbs along the bottom edge -->
          <div class="bulbs" aria-hidden="true">
            {bulbs.map((_, i) => (
              <span class="bulb" style={`animation-delay:${(i * 0.11).toFixed(2)}s`}></span>
            ))}
          </div>
        </div>
      </div>

      <!-- Lower area on a soft dark scrim so it reads over the photo -->
      <div class="lower">
        <p class="subtitle">A four-part strategy to re-stabilize a historic cultural corridor</p>
        <p class="credit">Brandon K. Engelhardt &middot; MS Urban Planning &middot; Drexel 2026</p>

        <!-- 6. Ticket-style buttons -->
        <p class="ticket-kicker">Also showing</p>
        <div class="tickets">
          <a class="ticket" href="/map?view=density">Not enough density</a>
          <a class="ticket" href="/map?view=outdoor">No outdoor space</a>
          <a class="ticket" href="/map?view=latenight">No Daytime Draw</a>
          <a class="ticket" href="/map?view=takeout">Too much takeout</a>
        </div>
        <div class="tickets">
          <a class="ticket" href="/map?view=healthy">Few Healthy Options</a>
          <a class="ticket" href="/map?view=aging">Aging Demographic</a>
          <a class="ticket" href="/map?view=culture">Arts &amp; Culture Loss</a>
          <a class="ticket" href="/map?view=smokeshops">Smoke Shops</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Flip the letter board between the "problems" front and the "bill" back.
  const flip = document.querySelector('[data-flip]');
  const board = flip && flip.closest('.board');
  const setFlipped = (state) => {
    if (!flip) return;
    flip.classList.toggle('flipped', state);        // rotates the faces
    if (board) board.classList.toggle('is-flipped', state); // swaps the frame carets
  };
  if (flip) {
    document.querySelectorAll('[data-flip-to-back]').forEach((btn) =>
      btn.addEventListener('click', () => setFlipped(true))
    );
    document.querySelectorAll('[data-flip-to-front]').forEach((btn) =>
      btn.addEventListener('click', () => setFlipped(false))
    );
  }
</script>

<style>
  .cover {
    /* Single knob to tune how dark it gets directly behind the marquee. */
    --overlay-darkness: 0.74;
    position: relative;
    min-height: calc(100dvh - 58px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2.5rem 1.5rem 3.5rem;
    background-color: #05070f;
    background-image: url('/images/website_background_2560x1440.jpg');
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }
  /* Dark overlay: darkest directly behind the marquee, easing lighter
     toward the edges so the bulbs glow and the text stays readable. */
  .cover::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 88% 82% at 50% 46%,
      rgba(3, 5, 12, var(--overlay-darkness)) 0%,
      rgba(3, 5, 12, calc(var(--overlay-darkness) - 0.30)) 62%,
      rgba(3, 5, 12, calc(var(--overlay-darkness) - 0.46)) 100%
    );
    pointer-events: none;
  }

  .stage {
    position: relative;
    width: min(92vw, 840px);
    margin: 0 auto;
    text-align: center;
  }

  /* ---- Marquee wrapper (anchors the lamppost) ---- */
  .marquee {
    position: relative;
  }

  /* ---- Lamppost ---- */
  .lamppost {
    position: absolute;
    left: -52px;
    bottom: -122px;                /* foot drops past the board to the tickets row */
    width: 60px;
    height: auto;
    pointer-events: none;          /* decorative; never blocks the tickets */
    filter: drop-shadow(0 0 6px rgba(0, 0, 0, 0.6));
    z-index: 3;
  }
  .lamp-glow {
    filter: blur(7px);
    transform-origin: center;
    animation: lampPulse 3.6s ease-in-out infinite;
  }
  @keyframes lampPulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.85; }
  }

  /* ---- 1. Small framed marquee sign ---- */
  .plate {
    position: relative;
    z-index: 3;                  /* sits on top of the board */
    width: fit-content;
    min-width: 50%;              /* roughly half to two-thirds of the board */
    max-width: 66%;
    margin: 0 auto -10px;        /* centered + slightly overlaps the board top */
    background: #ffffff;
    border: 2px solid #14140f;   /* black frame */
    border-radius: 4px;
    padding: 0.62rem 1.5rem 0.7rem;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.45);
    text-align: center;
  }
  /* Badge + title share one centered line */
  .plate-head {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
  }
  .sign-sub {
    margin-top: 0.32rem;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    text-indent: 0.24em;
    font-size: 0.58rem;
    color: rgba(20, 20, 15, 0.7);
  }
  .badge {
    width: 46px;
    height: 46px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(0, 0, 0, 0.5);
    border-radius: 50%;
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    font-size: 0.98rem;
    letter-spacing: 0.12em;
    color: #14140f;
    text-indent: 0.12em;
  }
  .brand {
    font-family: 'Bebas Neue', 'Anton', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    text-indent: 0.32em;
    color: #14140f;
    font-size: clamp(1.22rem, 4.9vw, 1.78rem);
    line-height: 1.1;
    -webkit-text-stroke: 0.5px currentColor;
  }
  .brand-sub {
    margin-top: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    text-indent: 0.26em;
    font-size: 0.6rem;
    color: rgba(214, 206, 190, 0.7);
  }

  /* ---- 2. Letter board ---- */
  /* Dark frame as a clean rounded rectangle around the flat board; the
     bulb string runs along its straight bottom edge. */
  .board {
    position: relative;
    z-index: 1;
    background: #0d0f14;           /* dark frame */
    border-radius: 10px;           /* clean rounded rectangle */
    padding: 11px 11px 28px;       /* frame + room for the bulb string */
    /* Soft drop shadow beneath -> reads as a box projecting off the wall;
       crisp 1px edge keeps the dark frame defined against the photo. */
    box-shadow:
      0 32px 60px rgba(0, 0, 0, 0.62),
      0 10px 22px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(0, 0, 0, 0.55),
      0 0 70px rgba(255, 224, 168, 0.09);
  }
  /* ---- 2a. Flip card: two flat faces that swing flat-to-flat ---- */
  .flip-frame {
    perspective: 1200px;
    overflow: hidden;             /* contains the swing; bulbs stay below, fully visible */
    border-radius: 3px;
  }
  .flip {
    position: relative;
    display: grid;                 /* both faces share one cell -> sizes to the taller */
    transform-style: preserve-3d;
    transition: transform 0.8s ease;
  }
  .flip.flipped {
    transform: rotateY(180deg);    /* swing to the opposite face */
  }
  /* Flat, straight rectangular faces (no clip-path, no tilt) */
  .face {
    grid-area: 1 / 1;              /* stack both faces in the same space */
    --channel: 2.4rem;            /* marquee slot height (shared by both faces) */
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;   /* top-aligned so the slots phase-lock to the grid */
    background-color: #f6f4ee;     /* changeable-letter white */
    /* Etched channel lines filling the WHOLE board, evenly spaced edge to edge */
    background-image: repeating-linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.16) 0,
      rgba(0, 0, 0, 0.16) 1px,
      rgba(255, 255, 255, 0.6) 1px,
      rgba(255, 255, 255, 0.6) 2px,
      transparent 2px,
      transparent var(--channel)
    );
    border-radius: 3px;
    overflow: hidden;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  /* Each line of text fills one slot, stacked from the top so they phase-lock
     to the etched grid; one empty slot of padding sits above. */
  .face-content {
    position: relative;            /* text sits above the etched lines */
    width: 100%;
    padding: var(--channel) 2.2rem 0;
  }
  /* Both faces use the base 1-slot top padding (one empty slot at the very top). */
  .face-front { pointer-events: auto; }
  .face-back {
    transform: rotateY(180deg);    /* pre-rotated so the text reads correctly when flipped */
    pointer-events: none;
  }
  /* Only the face currently showing is clickable */
  .flip.flipped .face-front { pointer-events: none; }
  .flip.flipped .face-back { pointer-events: auto; }
  .kicker {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--channel);    /* one slot */
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    font-size: 0.79rem;
    font-weight: 700;
    color: #c01a1a;
  }
  .board-lead {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--channel);    /* one slot */
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.9rem;
    color: #6b6459;
  }
  .rows {
    position: relative;
    margin-top: var(--channel);    /* one blank channel between header and the problems */
    text-align: left;
  }
  .row {
    display: flex;
    align-items: center;           /* text sits centered in its channel */
    justify-content: space-between;
    gap: 0.85rem;
    min-height: var(--channel);    /* one slot */
    padding: 0 1.1rem 0 0;         /* right gutter clears the right caret */
    text-decoration: none;
    transition: background-color 0.15s ease;
  }
  .row:hover,
  .row:focus-visible {
    background-color: rgba(192, 26, 26, 0.05);
    outline: none;
  }
  .prob {
    font-family: 'Anton', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.45rem, 4vw, 2.1rem);
    line-height: 1;
    color: #14140f;
  }
  .cue {
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.68rem;
    font-weight: 700;
    color: #c01a1a;
    white-space: nowrap;
  }

  /* ---- 2b. Flip controls + back "bill" ---- */
  /* Mounted on the stable .board frame, vertically centred on the edge,
     sitting against the dark so they pop (not buried in the cream). */
  .frame-caret {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    width: 38px;
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: none;
    border: none;
    color: #e0241f;                /* clean red */
    cursor: pointer;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.65));
    transition: color 0.15s ease, filter 0.15s ease;
  }
  .frame-caret svg {
    width: 28px;
    height: 28px;
  }
  .frame-caret:hover,
  .frame-caret:focus-visible {
    color: #ff463f;
    filter: drop-shadow(0 0 6px rgba(224, 36, 31, 0.6));
    outline: none;
  }
  .frame-caret-right { right: 14px; }                /* fully inside the white board */
  .frame-caret-left { left: 14px; display: none; }   /* hidden until flipped */
  .board.is-flipped .frame-caret-right { display: none; }
  .board.is-flipped .frame-caret-left { display: flex; }
  .headliner {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--channel);    /* one slot */
    font-family: 'Anton', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.7rem, 5vw, 2.1rem);
    line-height: 1;
    color: #14140f;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .headliner:hover,
  .headliner:focus-visible {
    background-color: rgba(192, 26, 26, 0.05);
    color: #c01a1a;
    outline: none;
  }
  .headliner-arrow {
    font-size: 0.42em;
    vertical-align: middle;
    margin-left: 0.4em;
    color: #c01a1a;
  }
  /* Secondary CTA sitting just under the headliner, phase-locked to one slot. */
  .bill-summary-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.35em;
    min-height: var(--channel);    /* one slot */
    text-transform: uppercase;
    letter-spacing: 0.14em;
    text-indent: 0.14em;
    font-size: 0.66rem;
    font-weight: 700;
    color: #c01a1a;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .bill-summary-cta:hover,
  .bill-summary-cta:focus-visible {
    color: #e0241f;
    text-decoration: underline;
    text-underline-offset: 2px;
    outline: none;
  }
  .bill-sub {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--channel);    /* one slot */
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.82rem;
    color: #6b6459;
  }
  .featuring-label {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: var(--channel);    /* one slot */
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    font-size: 0.66rem;
    font-weight: 700;
    color: #8a8175;
  }
  .acts {
    display: flex;
    flex-direction: column;
  }
  .act {
    display: flex;
    align-items: center;           /* text centered in its slot */
    justify-content: center;
    min-height: var(--channel);    /* one slot */
    padding: 0;
    font-family: 'Anton', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: clamp(1rem, 2.6vw, 1.35rem);
    line-height: 1.1;
    color: #2a2722;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }
  .act:hover,
  .act:focus-visible {
    background-color: rgba(192, 26, 26, 0.05);
    color: #c01a1a;
    outline: none;
  }

  /* ---- 3. Bulb string ---- */
  .bulbs {
    position: absolute;
    left: 15px;
    right: 15px;
    bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .bulb {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #ffcf73;
    box-shadow: 0 0 4px #ffbf57, 0 0 7px rgba(255, 157, 46, 0.7);
    animation: bulbChase 2.4s ease-in-out infinite;
  }
  @keyframes bulbChase {
    0%, 100% {
      opacity: 0.32;
      box-shadow: 0 0 2px rgba(255, 191, 87, 0.5);
    }
    50% {
      opacity: 1;
      box-shadow: 0 0 7px #ffcf73, 0 0 13px rgba(255, 157, 46, 0.85);
    }
  }

  /* ---- 5. Lower area: subtitle + byline + tickets on a soft scrim ---- */
  .lower {
    position: relative;
    margin-top: 0.5rem;
    padding: 1.1rem 1.6rem 0.7rem;
    border-radius: 16px;
    /* soft dark scrim so the text & tickets stay readable over the photo */
    background: radial-gradient(
      ellipse 96% 100% at 50% 44%,
      rgba(6, 8, 16, 0.52) 0%,
      rgba(6, 8, 16, 0) 72%
    );
  }
  .subtitle {
    margin: 0 auto;
    max-width: 40rem;
    font-family: Georgia, 'Times New Roman', ui-serif, serif;
    font-style: italic;
    font-size: 1rem;
    line-height: 1.45;
    color: rgba(247, 244, 236, 0.96);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }
  .credit {
    margin-top: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.66rem;
    color: rgba(228, 223, 211, 0.85);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
  }

  /* ---- 6. Ticket buttons ---- */
  .ticket-kicker {
    margin-top: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    font-size: 0.66rem;
    font-weight: 700;
    color: rgba(224, 218, 205, 0.88);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  .tickets {
    margin-top: 0.7rem;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }
  .ticket {
    position: relative;
    background: #f3efe4;
    color: #1a1813;
    text-decoration: none;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.66rem 1.1rem;
    border-radius: 4px;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.45);
    transition: transform 0.12s ease, background-color 0.12s ease;
  }
  /* Perforated ticket notches on the left & right edges */
  .ticket::before,
  .ticket::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 8px;
    height: 8px;
    background: #05070f;
    border-radius: 50%;
    transform: translateY(-50%);
  }
  .ticket::before { left: -4px; }
  .ticket::after { right: -4px; }
  .ticket:hover,
  .ticket:focus-visible {
    background: #fff;
    transform: translateY(-1px);
    outline: none;
  }
  /* Second "Also showing" row: blank placeholder tickets (no labels yet). They
     reuse .ticket for shape/spacing; the &nbsp; in the markup keeps the text-line
     height, and this min-width keeps the same ticket width the first row has so
     they don't collapse. Remove this class once real labels are added. */
  .ticket--placeholder {
    min-width: 8rem;
  }

  @media (max-width: 760px) {
    .lamppost { left: -26px; width: 52px; }
  }
  @media (max-width: 480px) {
    .lamppost { left: -6px; width: 44px; }
    .cue { display: none; }
  }

  /* ---- Mobile-only marquee polish (desktop unchanged) ---- */
  @media (max-width: 767px) {
    /* Left-align the stacked SAVING / SOUTH / STREET so the leading S of each
       word lines up down the card (text-indent would offset the first line). */
    .brand {
      text-align: left;
      text-indent: 0;
    }
    /* Keep the problem list off the left rail with a little breathing room. */
    .rows {
      padding-left: 0.55rem;
    }
  }

