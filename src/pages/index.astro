      border-radius: 2px;
      margin: 10px 8px;
    }
    .range-slider-fill {
      position: absolute;
      top: 0;
      bottom: 0;
      background: #1c1917;
      border-radius: 2px;
    }
    .range-slider-handle {
      position: absolute;
      top: 50%;
      left: -8px;
      width: calc(100% + 16px);
      height: 4px;
      margin: 0;
      padding: 0;
      background: transparent;
      pointer-events: none;
      -webkit-appearance: none;
      appearance: none;
      outline: none;
      transform: translateY(-50%);
    }
    .range-slider-handle::-webkit-slider-runnable-track {
      background: transparent;
      border: none;
      height: 4px;
    }
    .range-slider-handle::-moz-range-track {
      background: transparent;
      border: none;
      height: 4px;
    }
    .range-slider-handle::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      pointer-events: auto;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #1c1917;
      border: 2px solid #ffffff;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
      cursor: pointer;
      margin-top: 0;
    }
    .range-slider-handle::-moz-range-thumb {
      pointer-events: auto;
      width: 12px;
      height: 12px;
      border-radius: 50%;
      background: #1c1917;
      border: 2px solid #ffffff;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.2);
      cursor: pointer;
