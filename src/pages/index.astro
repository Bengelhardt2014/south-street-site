    // -------------------- Block-level metric aggregation --------------------
    // Cached once at page load. Used by the block-level heat ribbon UI below
    // the map. Aggregation is corridor + block_number, with five metrics per
    // block. Sidebar filters do NOT affect these numbers — the ribbon is a
    // stable "block character" view independent of parcel-level exploration.

    type BlockStat = {
      corridor: string;             // 'South Street' or 'East Passyunk'
      block_number: number;         // e.g., 300, 1600
      totals: { all: number; commercial: number; occupied: number };
      metrics: {
        vacancy_rate: number;       // 0-100 integer (vacant / commercial)
        outdoor_rate: number;       // 0-100 integer (outdoor=Yes / occupied)
        quick_service_rate: number; // 0-100 integer (quick service / occupied)
        nuisance_count: number;     // raw count
        local_chain_count: number;  // raw count
      };
      // Auxiliary detail for hover tooltips (Sub-phase C)
      vacant_count: number;
      outdoor_yes_count: number;
      quick_service_count: number;
      nuisance_addresses: string[];
      local_chain_addresses: string[];
      // Tooltip breakdowns
      nuisance_categories: string[];      // category per nuisance parcel
      local_chain_categories: string[];   // business_category per chain parcel
    };

    const NUISANCE_CATEGORIES = new Set<string>([
      'Smoke Shop',
      'Alternative Financial Services (AFS)',
    ]);
    const LOCAL_CHAIN_OPERATORS = new Set<string>([
      'Metro-only Chain',
      'Regional Chain',
    ]);

    let blockStats: BlockStat[] = [];

    function buildBlockStats(parcelsGj: GeoJSON.FeatureCollection): void {
      type Bucket = {
        all: number; commercial: number; occupied: number;
        vacant_count: number; outdoor_yes: number; quick_service: number;
        nuisance_addresses: string[]; local_chain_addresses: string[];
        nuisance_categories: string[]; local_chain_categories: string[];
      };
      const buckets = new Map<string, Bucket>();

      for (const f of parcelsGj.features) {
        const p = f.properties as ParcelProps;
        const bn = p.block_number;
        const corr = p.corridor;
        if (bn === null || bn === undefined || !corr) continue;
        const key = `${corr}|${bn}`;
        let b = buckets.get(key);
        if (!b) {
          b = {
            all: 0, commercial: 0, occupied: 0,
            vacant_count: 0, outdoor_yes: 0, quick_service: 0,
            nuisance_addresses: [], local_chain_addresses: [],
            nuisance_categories: [], local_chain_categories: [],
          };
          buckets.set(key, b);
        }
        b.all++;
        if (p.vacancy_state !== 'non_commercial') {
          b.commercial++;
          if (
            p.vacancy_state === 'short_term' ||
            p.vacancy_state === 'under_renovation' ||
            p.vacancy_state === 'long_term'
          ) {
            b.vacant_count++;
          }
          if (p.vacancy_state === 'active') {
            b.occupied++;
            if (p.outdoor_footprint === 'Yes') b.outdoor_yes++;
            const cat = p.business_category || '';
            // Match 'Quick Service' substring — handles the en-dash that breaks
            // exact-equality matches across encodings.
            if (cat.indexOf('Quick Service') !== -1) b.quick_service++;
          }
        }
        const cat = p.business_category;
        if (cat && NUISANCE_CATEGORIES.has(cat)) {
          b.nuisance_addresses.push(p.address || '');
          b.nuisance_categories.push(cat);
        }
        if (p.operator_type && LOCAL_CHAIN_OPERATORS.has(p.operator_type)) {
          b.local_chain_addresses.push(p.address || '');
          b.local_chain_categories.push(cat || '');
        }
      }

      const pct = (n: number, d: number): number =>
        d > 0 ? Math.round((n / d) * 100) : 0;

      blockStats = [];
      for (const [key, b] of buckets) {
        const [corr, bnStr] = key.split('|');
        blockStats.push({
          corridor: corr,
          block_number: Number(bnStr),
          totals: { all: b.all, commercial: b.commercial, occupied: b.occupied },
          metrics: {
            vacancy_rate: pct(b.vacant_count, b.commercial),
            outdoor_rate: pct(b.outdoor_yes, b.occupied),
            quick_service_rate: pct(b.quick_service, b.occupied),
            nuisance_count: b.nuisance_addresses.length,
            local_chain_count: b.local_chain_addresses.length,
          },
          vacant_count: b.vacant_count,
          outdoor_yes_count: b.outdoor_yes,
          quick_service_count: b.quick_service,
          nuisance_addresses: b.nuisance_addresses,
          local_chain_addresses: b.local_chain_addresses,
          nuisance_categories: b.nuisance_categories,
          local_chain_categories: b.local_chain_categories,
        });
      }
      blockStats.sort(
        (a, b) => a.corridor.localeCompare(b.corridor) || a.block_number - b.block_number,
      );
    }

    // -------------------- Block-level ribbon: colors + render --------------------
    type MetricKey =
      | 'vacancy_rate' | 'outdoor_rate' | 'quick_service_rate'
      | 'nuisance_count' | 'local_chain_count';

    const RAMP_CORAL = ['#FAECE7', '#F5C4B3', '#F0997B', '#D85A30', '#993C1D'];
    const RAMP_GREEN = ['#EAF3DE', '#C0DD97', '#97C459', '#639922', '#3B6D11'];
    const RAMP_AMBER = ['#FAEEDA', '#FAC775', '#EF9F27', '#BA7517', '#854F0B'];

    type MetricConfig = {
      label: string;
      ramp: string[];
      isPercent: boolean;
      // Returns the denominator value (or null for count metrics). Used for
      // the low-confidence check on percentage metrics.
      denominator: (s: BlockStat) => number | null;
    };
    const METRIC_CONFIGS: Record<MetricKey, MetricConfig> = {
      vacancy_rate:       { label: 'Vacancy rate',       ramp: RAMP_CORAL, isPercent: true,  denominator: (s) => s.totals.commercial },
      outdoor_rate:       { label: 'Outdoor footprint',  ramp: RAMP_GREEN, isPercent: true,  denominator: (s) => s.totals.occupied   },
      quick_service_rate: { label: 'Quick service',      ramp: RAMP_AMBER, isPercent: true,  denominator: (s) => s.totals.occupied   },
      nuisance_count:     { label: 'Nuisance retail',    ramp: RAMP_CORAL, isPercent: false, denominator: () => null                },
      local_chain_count:  { label: 'Local chains',       ramp: RAMP_GREEN, isPercent: false, denominator: () => null                },
    };
    const LOW_CONFIDENCE_THRESHOLD = 5;

    // Phrases used in the counter when a block is selected, appended in parens.
    const METRIC_PHRASES: Record<MetricKey, string> = {
      vacancy_rate: 'vacant',
      outdoor_rate: 'with outdoor footprint',
      quick_service_rate: 'quick service',
      nuisance_count: 'nuisance retail',
      local_chain_count: 'locally-grown chains',
    };

    function mixHexColors(a: string, b: string, t: number): string {
      const parseHex = (h: string): [number, number, number] => [
        parseInt(h.slice(1, 3), 16),
        parseInt(h.slice(3, 5), 16),
        parseInt(h.slice(5, 7), 16),
      ];
      const [ar, ag, ab] = parseHex(a);
      const [br, bg, bb] = parseHex(b);
      const r = Math.round(ar + (br - ar) * t);
      const g = Math.round(ag + (bg - ag) * t);
      const bl = Math.round(ab + (bb - ab) * t);
      return `rgb(${r}, ${g}, ${bl})`;
    }
    function colorForValue(value: number, max: number, ramp: string[]): string {
      // Zero = pure white (visually distinct "no presence" vs. tiny presence).
      if (value <= 0) return '#FFFFFF';
      if (max <= 1) return ramp[0];
      // Interpolate from ramp[0] at value=1 to ramp[N-1] at value=max.
      const ratio = (value - 1) / (max - 1);
      const clamped = Math.max(0, Math.min(1, ratio));
      const pos = clamped * (ramp.length - 1);
      const lower = Math.floor(pos);
      const upper = Math.min(ramp.length - 1, lower + 1);
      return mixHexColors(ramp[lower], ramp[upper], pos - lower);
    }
    function textColorForValue(value: number, max: number, ramp: string[]): string {
      // Zero cells use muted gray on white for readability.
      if (value <= 0) return '#57534e';
      if (max <= 1) return ramp[ramp.length - 1];
      const ratio = (value - 1) / (max - 1);
      // White text on the upper 40% of the ramp (where the cell is dark enough
      // that the darkest-stop text would have poor contrast).
      if (ratio >= 0.6) return '#FFFFFF';
      return ramp[ramp.length - 1];
    }
    function maxForMetric(metric: MetricKey): number {
      let m = 0;
      for (const s of blockStats) {
        const v = s.metrics[metric];
        if (v > m) m = v;
      }
      return m;
    }
    function formatValue(metric: MetricKey, value: number, lowConfidence: boolean): string {
      const cfg = METRIC_CONFIGS[metric];
      const base = cfg.isPercent ? `${value}%` : `${value}`;
      return lowConfidence ? base + '*' : base;
    }
    function isLowConfidenceForMetric(stat: BlockStat, metric: MetricKey): boolean {
      const cfg = METRIC_CONFIGS[metric];
      if (!cfg.isPercent) return false;
      const denom = cfg.denominator(stat);
      return denom !== null && denom < LOW_CONFIDENCE_THRESHOLD;
    }

    function renderRibbon(): void {
      if (blockStats.length === 0) return;
      const max = maxForMetric(filterState.activeMetric);
      const cfg = METRIC_CONFIGS[filterState.activeMetric];

      // Two corridor block lists, in fixed east->west order
      for (const corr of ['South Street', 'East Passyunk']) {
        const container = document.querySelector<HTMLElement>(
          `.ribbon-blocks[data-blocks-for="${corr}"]`,
        );
        if (!container) continue;
        const corrBlocks = blockStats
          .filter((b) => b.corridor === corr)
          .sort((a, b) => a.block_number - b.block_number);
        container.setAttribute('data-block-count', String(corrBlocks.length));

        const html: string[] = [];
        const bf = filterState.blockFilter;
        for (const stat of corrBlocks) {
          const v = stat.metrics[filterState.activeMetric];
          const bg = colorForValue(v, max, cfg.ramp);
          const fg = textColorForValue(v, max, cfg.ramp);
          const lowConf = isLowConfidenceForMetric(stat, filterState.activeMetric);
          const lowConfClass = lowConf ? ' is-low-conf' : '';
          const isSel =
            bf.corridor === stat.corridor && bf.block_number === stat.block_number;
          const selClass = isSel ? ' is-selected' : '';
          const valStr = formatValue(filterState.activeMetric, v, lowConf);
          html.push(
            `<div class="ribbon-block${lowConfClass}${selClass}" ` +
              `data-corridor="${escapeHtml(stat.corridor)}" ` +
              `data-block="${stat.block_number}" ` +
              `style="background:${bg}; color:${fg};">` +
              `<div class="ribbon-block-num">${stat.block_number}</div>` +
              `<div class="ribbon-block-val">${escapeHtml(valStr)}</div>` +
              `</div>`,
          );
        }
        container.innerHTML = html.join('');
      }

      // Legend gradient: full ramp left-to-right.
      const legendBar = document.getElementById('ribbon-legend-bar');
      if (legendBar) {
        const stops = cfg.ramp
          .map((c, i) => `${c} ${Math.round((i / (cfg.ramp.length - 1)) * 100)}%`)
          .join(', ');
        legendBar.style.background = `linear-gradient(90deg, ${stops})`;
      }
    }

    function wireRibbonControls(): void {
      const select = document.getElementById('ribbon-metric-select') as HTMLSelectElement | null;
      if (select) {
        select.addEventListener('change', () => {
          const v = select.value as MetricKey;
          if (METRIC_CONFIGS[v]) {
            filterState.activeMetric = v;
            renderRibbon();
            // Metric-implied filter changes when metric changes (only matters if
            // a block is selected, but always fire so the counter phrase updates).
            subscribers.forEach((fn) => fn());
          }
        });
      }
      wireRibbonToggle();
      wireRibbonBlockInteractions();
    }

    // -------------------- Ribbon: click + hover interactions --------------------
    function statForCell(cell: HTMLElement): BlockStat | null {
      const corridor = cell.dataset.corridor;
      const block = Number(cell.dataset.block);
      if (!corridor || !block) return null;
      return blockStats.find((s) => s.corridor === corridor && s.block_number === block) || null;
    }

    function boundsForBlock(corridor: string, blockNumber: number): L.LatLngBounds | null {
      if (!parcelsGjRef) return null;
      const pts: L.LatLng[] = [];
      for (const f of parcelsGjRef.features) {
        const p = f.properties as ParcelProps;
        if (p.corridor !== corridor || p.block_number !== blockNumber) continue;
        const coords = f.geometry && (f.geometry as GeoJSON.Point).coordinates;
        if (!coords) continue;
        const [lng, lat] = coords as [number, number];
        if (typeof lat === 'number' && typeof lng === 'number') {
          pts.push(L.latLng(lat, lng));
        }
      }
      return pts.length === 0 ? null : L.latLngBounds(pts);
    }

    function handleBlockClick(cell: HTMLElement): void {
      const corridor = cell.dataset.corridor || '';
      const block = Number(cell.dataset.block);
      if (!corridor || !block) return;
      const bf = filterState.blockFilter;
      const alreadySelected = bf.corridor === corridor && bf.block_number === block;
      if (alreadySelected) {
        // Clear: fly back to current corridor scope
        filterState.blockFilter = { corridor: null, block_number: null };
        flyToCorridor(filterState.corridor);
      } else {
        filterState.blockFilter = { corridor, block_number: block };
        const bounds = boundsForBlock(corridor, block);
        if (bounds && bounds.isValid() && mapRef) {
          mapRef.flyToBounds(bounds, { padding: [30, 30], duration: 0.9, maxZoom: 18 });
        }
      }
      updateRibbonSelection();
      subscribers.forEach((fn) => fn());
    }

    function updateRibbonSelection(): void {
      // Strip is-selected from any previously selected segment.
      document.querySelectorAll('.ribbon-block.is-selected').forEach((el) => {
        el.classList.remove('is-selected');
      });
      const bf = filterState.blockFilter;
      if (bf.corridor && bf.block_number !== null) {
        const sel = document.querySelector(
          `.ribbon-block[data-corridor="${CSS.escape(bf.corridor)}"][data-block="${bf.block_number}"]`,
        );
        if (sel) sel.classList.add('is-selected');
      }
    }

    function updateRibbonCorridorDimming(): void {
      const ssRow = document.querySelector('[data-corridor-row="south_street"]');
      const epRow = document.querySelector('[data-corridor-row="east_passyunk"]');
      if (!ssRow || !epRow) return;
      const c = filterState.corridor;
      ssRow.classList.toggle('is-dimmed', c === 'east-passyunk');
      epRow.classList.toggle('is-dimmed', c === 'south-street');
    }

    // -------------------- Ribbon: hover tooltip --------------------
    function buildTooltipHtml(stat: BlockStat, metric: MetricKey): string {
      const header =
        `<div class="ribbon-tooltip-header">${escapeHtml(stat.corridor)}, ${stat.block_number} block</div>`;
      const bodies: string[] = [];
      if (metric === 'vacancy_rate') {
        const v = stat.vacant_count;
        const c = stat.totals.commercial;
        bodies.push(
          `${v} of ${c} commercial parcel${c === 1 ? '' : 's'} vacant (${stat.metrics.vacancy_rate}%)`,
        );
        if (isLowConfidenceForMetric(stat, metric)) {
          bodies.push(`Small sample size (n=${c})`);
        }
      } else if (metric === 'outdoor_rate') {
        const o = stat.outdoor_yes_count;
        const occ = stat.totals.occupied;
        bodies.push(
          `${o} of ${occ} occupied parcel${occ === 1 ? '' : 's'} have outdoor footprint (${stat.metrics.outdoor_rate}%)`,
        );
        if (isLowConfidenceForMetric(stat, metric)) {
          bodies.push(`Small sample size (n=${occ})`);
        }
      } else if (metric === 'quick_service_rate') {
        const q = stat.quick_service_count;
        const occ = stat.totals.occupied;
        bodies.push(
          `${q} of ${occ} occupied parcel${occ === 1 ? '' : 's'} are quick service (${stat.metrics.quick_service_rate}%)`,
        );
        if (isLowConfidenceForMetric(stat, metric)) {
          bodies.push(`Small sample size (n=${occ})`);
        }
      } else if (metric === 'nuisance_count') {
        const n = stat.metrics.nuisance_count;
        bodies.push(`${n} nuisance parcel${n === 1 ? '' : 's'}`);
        if (n > 0) {
          let smoke = 0, afs = 0;
          for (const c of stat.nuisance_categories) {
            if (c === 'Smoke Shop') smoke++;
            else if (c === 'Alternative Financial Services (AFS)') afs++;
          }
          const parts: string[] = [];
          if (smoke) parts.push(`${smoke} Smoke Shop${smoke === 1 ? '' : 's'}`);
          if (afs) parts.push(`${afs} Alternative Financial Service${afs === 1 ? '' : 's'}`);
          if (parts.length) bodies.push(parts.join(', '));
        }
      } else if (metric === 'local_chain_count') {
        const n = stat.metrics.local_chain_count;
        bodies.push(`${n} locally-grown chain${n === 1 ? '' : 's'}`);
        if (n > 0 && n <= 3) {
          const cats = stat.local_chain_categories.filter((c) => c && c.length > 0);
          if (cats.length) bodies.push(cats.join(', '));
        }
      }
      return (
        header +
        bodies.map((b) => `<div class="ribbon-tooltip-body">${escapeHtml(b)}</div>`).join('')
      );
    }

    function showBlockTooltip(cell: HTMLElement): void {
      const stat = statForCell(cell);
      const tt = document.getElementById('ribbon-tooltip');
      if (!stat || !tt) return;
      tt.innerHTML = buildTooltipHtml(stat, filterState.activeMetric);
      tt.hidden = false;
      const cellRect = cell.getBoundingClientRect();
      const ttRect = tt.getBoundingClientRect();
      let arrow: 'down' | 'up' = 'down';
      let top = cellRect.top - ttRect.height - 10;
      if (top < 10) {
        arrow = 'up';
        top = cellRect.bottom + 10;
      }
      let left = cellRect.left + cellRect.width / 2 - ttRect.width / 2;
      left = Math.max(8, Math.min(left, window.innerWidth - ttRect.width - 8));
      tt.setAttribute('data-arrow', arrow);
      tt.style.top = `${top}px`;
      tt.style.left = `${left}px`;
    }
    function hideBlockTooltip(): void {
      const tt = document.getElementById('ribbon-tooltip');
      if (tt) tt.hidden = true;
    }

    function wireRibbonBlockInteractions(): void {
      const ribbon = document.getElementById('block-ribbon');
      if (!ribbon) return;
      ribbon.addEventListener('click', (e) => {
        const cell = (e.target as HTMLElement).closest<HTMLElement>('.ribbon-block');
        if (cell) handleBlockClick(cell);
      });
      ribbon.addEventListener('mouseover', (e) => {
        const cell = (e.target as HTMLElement).closest<HTMLElement>('.ribbon-block');
        if (cell) showBlockTooltip(cell);
      });
      ribbon.addEventListener('mouseout', (e) => {
        const cell = (e.target as HTMLElement).closest<HTMLElement>('.ribbon-block');
        if (!cell) return;
        const related = e.relatedTarget as HTMLElement | null;
        if (related && cell.contains(related)) return;
        hideBlockTooltip();
      });
    }

    // Block-ribbon collapse state lives at module scope so both the manual
    // toggle button and the corridor filter can drive it.
    let ribbonCollapsed = false;
    function applyRibbonState(collapsed: boolean): void {
      const wrapper = document.getElementById('block-ribbon-wrapper');
      const btn = document.getElementById('ribbon-toggle');
      if (!wrapper || !btn) return;
      ribbonCollapsed = collapsed;
      wrapper.classList.toggle('is-collapsed', collapsed);
      btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      btn.setAttribute('aria-label', collapsed ? 'Expand ribbon' : 'Collapse ribbon');
      // Let the CSS height transition finish, then ask Leaflet to recompute its
      // container size so tiles render at the new map height.
      window.setTimeout(() => {
        if (mapRef) mapRef.invalidateSize();
      }, 280);
    }

    // Corridor filter drives the ribbon: All Corridors collapses it; selecting a
    // single corridor auto-expands it. Manual toggling works between changes.
    function syncRibbonToCorridor(): void {
      applyRibbonState(filterState.corridor === 'all');
    }

    function wireRibbonToggle(): void {
      const btn = document.getElementById('ribbon-toggle');
      if (!btn) return;
      btn.addEventListener('click', () => {
        applyRibbonState(!ribbonCollapsed);
      });
    }

    // -------------------- Cultural anchor lens --------------------
    type LensState = 'active' | 'former' | 'policy' | 'other';

    // Halos and tooltips owned by the lens. Cleaned up on every render to
    // avoid stale visuals when corridor / sub-toggle changes mid-lens.
    let lensHaloLayers: L.CircleMarker[] = [];

    function classifyLens(p: ParcelProps): LensState {
      if (p.cultural_status === 'Active') return 'active';
      if (p.cultural_status === 'Former') return 'former';
      if (
        p.vacancy_state === 'long_term' &&
        (p.zone_type || '').startsWith('CMX') &&
        p.corridor === 'South Street'
      ) {
        return 'policy';
      }
      return 'other';
    }

    function cleanupLensVisuals(): void {
      // Remove halos
      for (const halo of lensHaloLayers) {
        if (mapRef && mapRef.hasLayer(halo)) mapRef.removeLayer(halo);
      }
      lensHaloLayers = [];
      // Unbind tooltips on parcel markers
      for (const { layer } of markerIndex.values()) {
        if (layer.getTooltip()) layer.unbindTooltip();
      }
    }

    function applyNormalMarkerStyle(layer: L.CircleMarker, p: ParcelProps): void {
      const vc = VACANCY_COLORS[p.vacancy_state] || '#888';
      layer.setStyle({
        radius: 7,
        fillColor: vc,
        color: '#ffffff',
        weight: 1,
        opacity: 1,
        fillOpacity: 0.9,
        dashArray: undefined,
      });
    }

    function applyLensStyle(layer: L.CircleMarker, p: ParcelProps, state: LensState): void {
      if (!mapRef) return;
      const vc = VACANCY_COLORS[p.vacancy_state] || '#888';
      if (state === 'active') {
        layer.setStyle({
          radius: 7,
          fillColor: vc,
          color: '#ffffff',
          weight: 1,
          opacity: 1,
          fillOpacity: 0.9,
          dashArray: undefined,
        });
        const halo = L.circleMarker(layer.getLatLng(), {
          radius: 12, fill: false, color: '#534AB7',
          weight: 2, opacity: 1, interactive: false,
        });
        halo.addTo(mapRef);
        lensHaloLayers.push(halo);
        if (p.cultural_tenant) {
          layer.bindTooltip(p.cultural_tenant, {
            permanent: true, direction: 'right', offset: [8, 0],
            className: 'cultural-label',
          });
        }
      } else if (state === 'former') {
        layer.setStyle({
          radius: 7,
          fillColor: vc,
          color: vc,
          weight: 2,
          opacity: 1,
          fillOpacity: 0,           // hollow
          dashArray: undefined,
        });
        const halo = L.circleMarker(layer.getLatLng(), {
          radius: 12, fill: false, color: '#534AB7',
          weight: 1.5, dashArray: '3,3', opacity: 1, interactive: false,
        });
        halo.addTo(mapRef);
        lensHaloLayers.push(halo);
        if (p.cultural_tenant) {
          layer.bindTooltip(p.cultural_tenant, {
            permanent: true, direction: 'right', offset: [8, 0],
            className: 'cultural-label cultural-label-faded',
          });
        }
      } else if (state === 'policy') {
        layer.setStyle({
          radius: 7,
          fillColor: '#BA7517',
          color: '#BA7517',
          weight: 1.5,
          opacity: 1,
          fillOpacity: 0.2,
          dashArray: '2,3',
        });
      } else {
        // Other — dimmed
        layer.setStyle({
          radius: 7,
          fillColor: vc,
          color: '#ffffff',
          weight: 1,
          opacity: 0.25,
          fillOpacity: 0.25,
          dashArray: undefined,
        });
      }
    }

    function applyNormalNonCommercialStyle(layer: L.CircleMarker): void {
      layer.setStyle({
        radius: 7,
        fillColor: VACANCY_COLORS.non_commercial,
        color: '#ffffff',
        weight: 1,
        opacity: 0.4,
        fillOpacity: 0.35,
        dashArray: undefined,
      });
    }

    function renderLensMode(): void {
      if (!mapRef) return;
      cleanupLensVisuals();
      const choice = filterState.corridor;
      const bf = filterState.blockFilter;
      const ncVisible = shouldShowNonCommercialLayer();
      const inScope = (props: ParcelProps): boolean => {
        const inCorridor =
          choice === 'all' ||
          (choice === 'south-street'  && props.corridor === 'South Street') ||
          (choice === 'east-passyunk' && props.corridor === 'East Passyunk');
        const inBlock =
          bf.corridor === null || bf.block_number === null ||
          (props.corridor === bf.corridor && props.block_number === bf.block_number);
        return inCorridor && inBlock;
      };
      // Commercial + vacant
      for (const { layer, props } of markerIndex.values()) {
        if (!inScope(props)) {
          if (mapRef.hasLayer(layer)) mapRef.removeLayer(layer);
          continue;
        }
        if (!mapRef.hasLayer(layer)) layer.addTo(mapRef);
        applyLensStyle(layer, props, classifyLens(props));
      }
      // Non-commercial (only when layer should be visible)
      for (const { layer, props } of nonCommercialMarkerIndex.values()) {
        const show = ncVisible && inScope(props);
        if (show) {
          if (!mapRef.hasLayer(layer)) layer.addTo(mapRef);
          applyLensStyle(layer, props, classifyLens(props));
        } else {
          if (mapRef.hasLayer(layer)) mapRef.removeLayer(layer);
        }
      }
    }

    function renderNormalMode(): void {
      if (!mapRef) return;
      cleanupLensVisuals();
      const ncVisible = shouldShowNonCommercialLayer();
      // Commercial + vacant
      for (const { layer, props } of markerIndex.values()) {
        applyNormalMarkerStyle(layer, props);
        const visible = matchesAll(props);
        if (visible) {
          if (!mapRef.hasLayer(layer)) layer.addTo(mapRef);
        } else {
          if (mapRef.hasLayer(layer)) mapRef.removeLayer(layer);
        }
      }
      // Non-commercial (only when layer should be visible; participates in matchesAll)
      for (const { layer, props } of nonCommercialMarkerIndex.values()) {
        applyNormalNonCommercialStyle(layer);
        const visible = ncVisible && matchesAll(props);
        if (visible) {
          if (!mapRef.hasLayer(layer)) layer.addTo(mapRef);
        } else {
          if (mapRef.hasLayer(layer)) mapRef.removeLayer(layer);
        }
      }
    }

    // -------------------- Showing-N-of-M corridor counter --------------------
    function updateCorridorCounter(): void {
      const el = document.getElementById('corridor-counter');
      if (!el || !parcelsGjRef) return;
      const choice = filterState.corridor;
      const scopeName = choice === 'south-street' ? 'South Street'
                      : choice === 'east-passyunk' ? 'East Passyunk'
                      : '';
      const bf = filterState.blockFilter;
      const blockActive = bf.corridor !== null && bf.block_number !== null;

      const includeNc = shouldShowNonCommercialLayer();

      // Block selected: report visible vs block scope total, with metric suffix
      if (blockActive && !filterState.culturalLens) {
        let visible = 0, scopeTotal = 0;
        for (const f of parcelsGjRef.features) {
          const p = f.properties as ParcelProps;
          if (p.vacancy_state === 'non_commercial' && !includeNc) continue;
          if (p.corridor !== bf.corridor || p.block_number !== bf.block_number) continue;
          scopeTotal++;
          if (matchesAll(p)) visible++;
        }
        const phrase = METRIC_PHRASES[filterState.activeMetric];
        el.textContent =
          `Showing ${visible} of ${scopeTotal} ${bf.corridor} ${bf.block_number} block parcels (${phrase})`;
        return;
      }

      // Lens mode: report counts of the four lens states (active/former/policy).
      if (filterState.culturalLens) {
        let active = 0, former = 0, policy = 0;
        for (const f of parcelsGjRef.features) {
          const p = f.properties as ParcelProps;
          if (p.vacancy_state === 'non_commercial' && !includeNc) continue;
          const inScope =
            choice === 'all' ||
            (choice === 'south-street'  && p.corridor === 'South Street') ||
            (choice === 'east-passyunk' && p.corridor === 'East Passyunk');
          if (!inScope) continue;
          if (blockActive && (p.corridor !== bf.corridor || p.block_number !== bf.block_number)) continue;
          const s = classifyLens(p);
          if (s === 'active') active++;
          else if (s === 'former') former++;
          else if (s === 'policy') policy++;
        }
        let tail = '';
        if (blockActive) tail = ` in ${bf.corridor} ${bf.block_number} block`;
        else if (scopeName) tail = ` on ${scopeName}`;
        el.textContent = `Showing ${active} active anchor${active === 1 ? '' : 's'}, ${former} former, ${policy} policy candidate${policy === 1 ? '' : 's'}${tail}`;
        return;
      }

      // Normal mode: visible vs scope total.
      let visible = 0;
      let scopeTotal = 0;
      for (const f of parcelsGjRef.features) {
        const p = f.properties as ParcelProps;
        if (p.vacancy_state === 'non_commercial' && !includeNc) continue;
        const inScope =
          choice === 'all' ||
          (choice === 'south-street'  && p.corridor === 'South Street') ||
          (choice === 'east-passyunk' && p.corridor === 'East Passyunk');
        if (!inScope) continue;
        scopeTotal++;
        if (matchesAll(p)) visible++;
      }
      if (choice === 'all') {
        el.textContent = `Showing ${visible} parcels`;
      } else {
        el.textContent = `Showing ${visible} of ${scopeTotal} ${scopeName} parcels`;
      }
    }

    // -------------------- Corridor section Reset (clears block filter) --------------------
    function wireCorridorReset(): void {
      const section = document.querySelector('[data-section="corridor"]');
      if (!section) return;
      section.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (!target.matches('.filter-section-reset[data-reset="corridor"]')) return;
        if (filterState.blockFilter.corridor === null) return;
        filterState.blockFilter = { corridor: null, block_number: null };
        flyToCorridor(filterState.corridor);
        updateRibbonSelection();
        subscribers.forEach((fn) => fn());
      });
    }

    // -------------------- Corridor centerline dim/restore --------------------
    // Opacity values:
    //   selected (or 'all' = neither dimmed) -> 0.4 (the current full opacity)
    //   unselected -> 0.12 (30% of 0.4) — "fades to 30% opacity" interpreted as
    //   30% of the line's current presence so the visual differentiation is
    //   clear rather than barely perceptible.
    // Smooth transition handled by CSS on .corridor-line (stroke-opacity 300ms).
    const CORRIDOR_LINE_FULL = 0.4;
    const CORRIDOR_LINE_DIM = 0.12;

    function updateCorridorLineOpacities(): void {
      if (!streetsLayerRef) return;
      const choice = filterState.corridor;
      streetsLayerRef.eachLayer((layer) => {
        const f = (layer as L.GeoJSON & { feature?: GeoJSON.Feature }).feature;
        const key = f?.properties?.corridor as string | undefined;
        let opacity = CORRIDOR_LINE_FULL;
        if (choice !== 'all') {
          const expectedKey = choice === 'south-street' ? 'south_street' : 'east_passyunk';
          if (key !== expectedKey) opacity = CORRIDOR_LINE_DIM;
        }
        (layer as L.Path).setStyle({ opacity });
      });
    }

    // -------------------- Sticky-state observer for the Corridor section --------------------
    function wireStickyCorridorObserver(): void {
      const sidebar = document.querySelector<HTMLElement>('.map-sidebar');
      const sentinel = document.querySelector<HTMLElement>('.sticky-sentinel');
      const corridorSec = document.querySelector<HTMLElement>('[data-section="corridor"]');
      if (!sidebar || !sentinel || !corridorSec) return;
      // The sentinel sits just above the Corridor section. When it scrolls
      // out of the sidebar's viewport (entry.isIntersecting === false), the
      // Corridor section is stuck.
      const obs = new IntersectionObserver(
        ([entry]) => {
          corridorSec.classList.toggle('is-stuck', !entry.isIntersecting);
        },
        { root: sidebar, threshold: 0 },
      );
      obs.observe(sentinel);
    }

    // -------------------- Corridor segmented control --------------------
    function flyToCorridor(choice: CorridorChoice): void {
      if (!mapRef) return;
      if (choice === 'all') {
        if (combinedCorridorBounds && combinedCorridorBounds.isValid()) {
          mapRef.flyToBounds(combinedCorridorBounds, { padding: [60, 60], duration: 0.9 });
        } else if (initialView) {
          mapRef.flyTo(initialView.center, initialView.zoom, { duration: 0.9 });
        }
        return;
      }
      const key = choice === 'south-street' ? 'south_street' : 'east_passyunk';
      const bounds = corridorBounds[key];
      if (bounds && bounds.isValid()) {
        mapRef.flyToBounds(bounds, { padding: [40, 40], duration: 0.9 });
      }
    }

    function wireCorridorSegmented(): void {
      const wrap = document.querySelector<HTMLElement>(
        '[data-section="corridor"] .corridor-segmented',
      );
      if (!wrap) return;
      wrap.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.corridor-segment');
        if (!btn) return;
        const value = btn.dataset.value as CorridorChoice | undefined;
        if (!value || filterState.corridor === value) return;
        filterState.corridor = value;
        // Corridor change clears any block selection.
        filterState.blockFilter = { corridor: null, block_number: null };
        wrap.querySelectorAll<HTMLButtonElement>('.corridor-segment').forEach((b) => {
          b.setAttribute('aria-pressed', b === btn ? 'true' : 'false');
        });
        flyToCorridor(value);
        updateCorridorLineOpacities();
        updateRibbonSelection();
        updateRibbonCorridorDimming();
        syncRibbonToCorridor();   // All → collapse, single corridor → expand
        subscribers.forEach((fn) => fn());
      });
    }

    // -------------------- Sidebar event wiring --------------------
    function wireBusinessMixSidebar(): void {
      const section = document.querySelector('[data-section="business-mix"]');
      if (!section) return;

      // change events: checkboxes + outdoor toggle
      section.addEventListener('change', (e) => {
        const t = e.target as HTMLInputElement;
        if (!t || !(t instanceof HTMLInputElement)) return;

        if (t.classList.contains('filter-vacancy')) {
          const v = t.dataset.value || '';
          if (t.checked) filterState.vacancy.add(v);
          else filterState.vacancy.delete(v);
          subscribers.forEach((fn) => fn());
        } else if (t.classList.contains('segment-parent')) {
          const seg = t.dataset.segment || '';
          const cats = segmentMap.get(seg) || [];
          if (t.checked) cats.forEach((c) => filterState.category.add(c));
          else cats.forEach((c) => filterState.category.delete(c));
          t.indeterminate = false;
          // sync children checkboxes
          document
            .querySelectorAll<HTMLInputElement>(
              `.filter-category[data-segment="${CSS.escape(seg)}"]`,
            )
            .forEach((c) => { c.checked = t.checked; });
          subscribers.forEach((fn) => fn());
        } else if (t.classList.contains('filter-category')) {
          const cat = t.dataset.category || '';
          const seg = t.dataset.segment || '';
          if (t.checked) filterState.category.add(cat);
          else filterState.category.delete(cat);
          syncSegmentParent(seg);
          subscribers.forEach((fn) => fn());
        } else if (t.id === 'filter-outdoor') {
          filterState.outdoorOnly = t.checked;
          subscribers.forEach((fn) => fn());
        } else if (t.id === 'filter-lens') {
          filterState.culturalLens = t.checked;
          subscribers.forEach((fn) => fn());
        }
      });

      // click events: chips + segment expand toggle
      section.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        if (!t) return;

        // Chip toggle
        const chip = t.closest('.chip') as HTMLButtonElement | null;
        if (chip) {
          const groupEl = chip.closest('.chip-row');
          const group = groupEl?.getAttribute('data-chip-group');
          const val = chip.dataset.value || '';
          const pressed = chip.getAttribute('aria-pressed') === 'true';
          chip.setAttribute('aria-pressed', pressed ? 'false' : 'true');
          if (group === 'operator') {
            if (pressed) filterState.operator.delete(val);
            else filterState.operator.add(val);
          } else if (group === 'peak') {
            const n = Number(val);
            if (pressed) filterState.peak.delete(n);
            else filterState.peak.add(n);
          } else if (group === 'price') {
            const n = Number(val);
            if (pressed) filterState.price.delete(n);
            else filterState.price.add(n);
          }
          subscribers.forEach((fn) => fn());
          return;
        }

        // Segment expand/collapse: clicks on chevron or label (not checkbox)
        const headerEl = t.closest('.segment-header');
        if (headerEl && !t.closest('.segment-parent')) {
          const segEl = headerEl.closest('.segment');
          if (segEl) toggleSegmentExpand(segEl);
        }

        // Reset link
        if (t.matches('.filter-section-reset[data-reset="business-mix"]')) {
          resetBusinessMix();
          subscribers.forEach((fn) => fn());
        }
      });
    }

    // -------------------- Building mix wiring --------------------
    function wireBuildingMixSidebar(): void {
      const section = document.querySelector('[data-section="building-mix"]');
      if (!section) return;

      // Chip toggles + Reset link
      section.addEventListener('click', (e) => {
        const t = e.target as HTMLElement;
        if (!t) return;

        const chip = t.closest('.chip') as HTMLButtonElement | null;
        if (chip) {
          const groupEl = chip.closest('.chip-row');
          const group = groupEl?.getAttribute('data-chip-group');
          const val = chip.dataset.value || '';
          const pressed = chip.getAttribute('aria-pressed') === 'true';
          chip.setAttribute('aria-pressed', pressed ? 'false' : 'true');
          if (group === 'ownership') {
            if (pressed) filterState.ownership.delete(val);
            else filterState.ownership.add(val);
          } else if (group === 'zone') {
            if (pressed) filterState.zone.delete(val);
            else filterState.zone.add(val);
          }
          subscribers.forEach((fn) => fn());
          return;
        }

        if (t.matches('.filter-section-reset[data-reset="building-mix"]')) {
          resetBuildingMix();
          subscribers.forEach((fn) => fn());
        }
      });

      // Range slider drag events — dispatch by data-range-group on the wrapper
      section.addEventListener('input', (e) => {
        const t = e.target as HTMLInputElement;
        if (!t) return;
        const sliderEl = t.closest<HTMLElement>('.range-slider');
        const groupId = sliderEl?.getAttribute('data-range-group') || '';
        const cfg = SLIDER_CONFIGS[groupId];
        if (!cfg) return;
        const state = filterState[cfg.stateKey];
        const isMin = t.classList.contains('range-slider-handle-min');
        const isMax = t.classList.contains('range-slider-handle-max');
        if (!isMin && !isMax) return;
        let newVal = Number(t.value);
        if (isMin) {
          if (newVal > state.max) { newVal = state.max; t.value = String(newVal); }
          state.min = newVal;
        } else {
          if (newVal < state.min) { newVal = state.min; t.value = String(newVal); }
          state.max = newVal;
        }
        updateRangeSliderUI(groupId);
        subscribers.forEach((fn) => fn());
      });
    }

    // -------------------- Marker index --------------------
    // Captured during pointToLayer for the commercial+vacant layer so the
    // subscribe callback can iterate without re-walking the GeoJSON.
    const markerIndex = new Map<
      number,
      { layer: L.CircleMarker; props: ParcelProps }
    >();
    // Non-commercial markers tracked individually so they can participate in
    // matchesAll / lens visibility instead of being a wholesale layer toggle.
    const nonCommercialMarkerIndex = new Map<
      number,
      { layer: L.CircleMarker; props: ParcelProps }
    >();

    // -------------------- Module-scope references for corridor navigation --------------------
    let parcelsGjRef: GeoJSON.FeatureCollection | null = null;
    let mapRef: L.Map | null = null;
    let initialView: { center: L.LatLng; zoom: number } | null = null;
    const corridorBounds: Record<string, L.LatLngBounds> = {};
    let combinedCorridorBounds: L.LatLngBounds | null = null;
    let streetsLayerRef: L.GeoJSON | null = null;
    // Boundary overlays (BID / RCO) — created lazily, default OFF, live in a
    // dedicated low-z pane below the parcel dots.
    let bidLayerRef: L.GeoJSON | null = null;
    let rcoLayerRef: L.GeoJSON | null = null;
    let zoningLayerRef: L.GeoJSON | null = null;
    let densityLayerRef: L.GeoJSON | null = null;
    let ringLayerRef: L.GeoJSON | null = null;

    function line(label: string, value: string | number): string {
      return `<p><span class="popup-label">${label}:</span> ${value}</p>`;
    }

    function buildPopup(p: ParcelProps): string {
      const isNonCommercial = p.vacancy_state === 'non_commercial';
      const isVacant =
        p.vacancy_state === 'short_term' ||
        p.vacancy_state === 'long_term' ||
        p.vacancy_state === 'under_renovation';

      // ---------- Header block ----------
      const header: string[] = [];
      header.push(`<h3 class="popup-address">${escapeHtml(p.address)}</h3>`);

      if (p.cultural_tenant && p.cultural_status) {
        const label =
          p.cultural_status === 'Active'
            ? 'Active Cultural Anchor'
            : `${escapeHtml(p.cultural_status)} Cultural Anchor`;
        header.push(
          `<p class="popup-subheader">${escapeHtml(p.cultural_tenant)} (${label})</p>`,
        );
      }

      if (isVacant && p.vacancy_type) {
        const pillClass = `popup-pill popup-pill--${p.vacancy_state}`;
        header.push(
          `<div class="popup-pill-row"><span class="${pillClass}">${escapeHtml(p.vacancy_type)}</span></div>`,
        );
      }

      // ---------- BUSINESS INFO section ----------
      const businessInfo: string[] = [];
      if (isVacant) {
        if (p.vacancy_type) businessInfo.push(line('Vacancy', escapeHtml(p.vacancy_type)));
        if (p.outdoor_footprint) businessInfo.push(line('Outdoor Footprint', escapeHtml(p.outdoor_footprint)));
      } else if (!isNonCommercial) {
        if (p.business_segment) businessInfo.push(line('Segment', escapeHtml(p.business_segment)));
        if (p.business_category) businessInfo.push(line('Category', escapeHtml(p.business_category)));
        if (p.operator_type && p.operator_type !== 'Vacant') {
          businessInfo.push(line('Operator', escapeHtml(p.operator_type)));
        }
        if (p.outdoor_footprint) businessInfo.push(line('Outdoor Footprint', escapeHtml(p.outdoor_footprint)));
      }

      // ---------- BUILDING DETAILS section ----------
      const buildingDetails: string[] = [];
      if (p.owner) buildingDetails.push(line('Owner', escapeHtml(titleCaseOwner(p.owner))));
      if (isNonCommercial && p.opa_property_use) {
        buildingDetails.push(line('Type', escapeHtml(p.opa_property_use)));
      }
      if (p.year_built) {
        buildingDetails.push(line('Year built', escapeHtml(p.year_built)));
      }
      if (p.zone_type) buildingDetails.push(line('Zone', escapeHtml(p.zone_type)));
      if (p.building_footprint && p.building_footprint > 0) {
        buildingDetails.push(
          line('Footprint', `${p.building_footprint.toLocaleString('en-US')} sqft`),
        );
      }
      if (p.building_height && p.building_height > 0) {
        buildingDetails.push(line('Height', `${p.building_height} ft`));
      }
      if (p.open_violations && p.open_violations > 0) {
        const valHtml = p.open_violations >= 3
          ? `<span class="popup-violations-high">${p.open_violations}</span>`
          : `${p.open_violations}`;
        buildingDetails.push(line('Open violations', valHtml));
      }
      if (
        p.last_sale_year &&
        p.last_sale_price !== null &&
        p.last_sale_price !== undefined
      ) {
        buildingDetails.push(
          line('Last sale', `${p.last_sale_year} for ${formatPrice(p.last_sale_price)}`),
        );
        if (Number(p.last_sale_price) === 1) {
          buildingDetails.push(
            `<p class="popup-caveat">(non-arms-length transfer)</p>`,
          );
        }
      }

      // ---------- Assemble ----------
      let html = header.join('');
      if (businessInfo.length) {
        html +=
          `<div class="popup-section">` +
          `<div class="popup-section-title">Business Info</div>` +
          businessInfo.join('') +
          `</div>`;
      }
      if (buildingDetails.length) {
        html +=
          `<div class="popup-section">` +
          `<div class="popup-section-title">Building Details</div>` +
          buildingDetails.join('') +
          `</div>`;
      }
      return html;
    }

    // Build the BID + RCO boundary layers (default OFF) and wire their sidebar
    // checkboxes. Layers live in the 'boundaries' pane so they sit below dots.
    async function initBoundaryOverlays(map: L.Map): Promise<void> {
      // At/above this zoom a single block roughly fills the viewport, so RCO
      // hover labels are suppressed to avoid interfering with block inspection.
      const RCO_HOVER_DISABLE_ZOOM = 18;
      const rcoHoverDisabled = () => map.getZoom() >= RCO_HOVER_DISABLE_ZOOM;

      // ================= Neighborhood demographic card =================
      // Maps between demographic neighborhood names and RCO shape names. Only
      // the five with both data AND a shape are clickable on the map; East
      // Passyunk Crossing has a shape but no data (boundary only), and Pennsport
      // has data but no shape (sidebar trigger only).
      type DecadeRec = Record<string, number | null>;
      type NbhdRec = {
        corridor: string;
        decades: Record<string, DecadeRec>;
        note?: string;
        partial?: boolean;
      };
      // RCO shape name -> demographic card key. Five shapes carry data; the EPX
      // shape shares the Passyunk Square (East Passyunk catchment) card. Shapes
      // not listed here (South Street/Headhouse District) stay boundary-only.
      const RCO_TO_NBHD: Record<string, string> = {
        'Society Hill Civic Association': 'Society Hill',
        'Washington Square West Civic Association': 'Washington Square West',
        'Queen Village Neighbors Association': 'Queen Village',
        'Bella Vista Neighbors Association': 'Bella Vista',
        'Passyunk Square Civic Association': 'Passyunk Square',
        'East Passyunk Crossing Civic Association (EPX)': 'Passyunk Square',
      };
      // Card key -> every RCO shape it should highlight. Passyunk Square covers
      // both the Passyunk Square and EPX shapes. WSW highlights a tract instead
      // (handled separately), so it lists no RCO shapes.
      const NBHD_TO_SHAPES: Record<string, string[]> = {
        'Society Hill': ['Society Hill Civic Association'],
        'Washington Square West': [],
        'Queen Village': ['Queen Village Neighbors Association'],
        'Bella Vista': ['Bella Vista Neighbors Association'],
        'Passyunk Square': [
          'Passyunk Square Civic Association',
          'East Passyunk Crossing Civic Association (EPX)',
        ],
        'Pennsport': [],
      };
      const TRACT_CARDS = new Set(['Washington Square West']);

      let demographics: Record<string, NbhdRec> = {};
      try {
        const resp = await fetch('/data/neighborhood_demographics.json');
        demographics = await resp.json();
      } catch (err) {
        console.error('Failed to load neighborhood_demographics.json', err);
      }

      // Highlight state: a set of RCO sublayers (one or two) and/or the WSW tract
      // layer. activeShapeNames lets us restore the RCO highlight if the layer is
      // toggled off and back on while the card is open.
      let highlightedRcoLayers: L.Path[] = [];
      let wswTractLayer: L.GeoJSON | null = null;
      let activeShapeNames: string[] = [];
      let activeNbhd: string | null = null;
      // Map view captured before flying to a neighborhood, restored on card close.
      let preCardView: { center: L.LatLng; zoom: number } | null = null;

      const INC = 'Median Household Income (2020$)';
      const HOME = 'Median Home Value (2020$)';

      // --- formatting helpers ---
      const fmtInt = (v: number | null) =>
        v == null ? '—' : Math.round(v).toLocaleString('en-US');
      const fmtMoney = (v: number | null) =>
        v == null ? '—' : '$' + Math.round(v).toLocaleString('en-US');
      const fmtPct = (frac: number | null) =>
        frac == null ? '—' : Math.round(frac * 100) + '%';
      const fmtAge = (v: number | null) =>
        v == null ? '—' : Number.isInteger(v) ? String(v) : v.toFixed(1);
      const pctChange = (oldV: number | null, newV: number | null): string => {
        if (oldV == null || newV == null || oldV === 0) return '';
        const p = Math.round(((newV - oldV) / oldV) * 100);
        return (p >= 0 ? '+' : '') + p + '% since 1970';
      };
      const yearsChange = (oldV: number | null, newV: number | null): string => {
        if (oldV == null || newV == null) return '';
        const n = Math.round(newV - oldV);
        return (n >= 0 ? '+' : '') + n + ' yrs since 1970';
      };
      const ppChange = (oldV: number | null, newV: number | null): string => {
        if (oldV == null || newV == null) return '';
        const n = Math.round((newV - oldV) * 100);
        return (n >= 0 ? '+' : '') + n + ' pts since 1970';
      };
      // mode 'neutral' → always grey (median age in years). mode 'signed' →
      // green up / red down, with an exact-zero change shown grey (neither).
      const deltaSpan = (s: string, mode: 'signed' | 'neutral'): string => {
        if (!s) return '';
        let cls = 'nbhd-delta';
        if (mode === 'neutral') {
          cls += ' is-neutral';
        } else {
          const m = s.match(/^([+-]?)(\d+)/);
          const num = m ? Number(m[1] + m[2]) : 0;
          if (num < 0) cls += ' is-negative';
          else if (num === 0) cls += ' is-neutral';
        }
        return `<span class="${cls}">${s}</span>`;
      };

      // Build the card body HTML for one neighborhood.
      const buildCardHtml = (name: string): string => {
        const rec = demographics[name];
        if (!rec) return '';
        const a: DecadeRec = rec.decades['1970'] || {};
        const b: DecadeRec = rec.decades['2020'] || {};
        const isEast = rec.corridor === 'East Passyunk';
        const stat = (label: string, value: string, delta = '') =>
          `<div class="nbhd-stat"><dt>${label}</dt><dd>${value}${delta}</dd></div>`;
        // Corridor vacancy line: South Street only, pairing current vs. the 1995
        // trough. East Passyunk cards show no vacancy line.
        const vacancyLine = isEast
          ? ''
          : `<p class="nbhd-card-vacancy">South Street corridor: ` +
            `<span class="nbhd-vacancy-now">${SOUTH_ST_VACANCY_CURRENT}% vacant</span>` +
            `<span class="nbhd-vacancy-base">, up from ${SOUTH_ST_VACANCY_1995}% in 1995</span></p>`;
        return (
          `<button class="nbhd-card-close" type="button" aria-label="Close">&times;</button>` +
          `<h3 class="nbhd-card-title">${escapeHtml(name)}</h3>` +
          `<p class="nbhd-card-subtitle${isEast ? ' is-east' : ''}">${escapeHtml(rec.corridor)} corridor</p>` +
          `<dl class="nbhd-stats">` +
            stat('Population (2020)', fmtInt(b['Total Population'])) +
            stat('Median household income', fmtMoney(b[INC]), deltaSpan(pctChange(a[INC], b[INC]), 'signed')) +
            stat('Median home value', fmtMoney(b[HOME]), deltaSpan(pctChange(a[HOME], b[HOME]), 'signed')) +
            stat('Owner-occupied', fmtPct(b['% Owner-Occupied']), deltaSpan(ppChange(a['% Owner-Occupied'], b['% Owner-Occupied']), 'signed')) +
            stat('Median age', fmtAge(b['Median Age']), deltaSpan(yearsChange(a['Median Age'], b['Median Age']), 'neutral')) +
            stat('Age 18–34', fmtPct(b['% 18-34']), deltaSpan(ppChange(a['% 18-34'], b['% 18-34']), 'signed')) +
          `</dl>` +
          vacancyLine +
          (rec.note ? `<p class="nbhd-card-note">${escapeHtml(rec.note)}</p>` : '') +
          `<p class="nbhd-card-footnote">Dollar figures inflation-adjusted to 2020.</p>`
        );
      };

      // Card lives in a Leaflet control docked top-right; hidden until selected.
      let cardEl: HTMLElement | null = null;
      const cardControl = new L.Control({ position: 'topright' });
      cardControl.onAdd = () => {
        const div = L.DomUtil.create('div', 'nbhd-card');
        div.style.position = 'relative';
        div.style.display = 'none';
        L.DomEvent.disableClickPropagation(div);
        L.DomEvent.disableScrollPropagation(div);
        div.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).closest('.nbhd-card-close')) closeCard();
        });
        cardEl = div;
        return div;
      };
      cardControl.addTo(map);

      const featName = (l: L.Layer) =>
        (l as L.GeoJSON & { feature?: GeoJSON.Feature }).feature?.properties?.name as
          | string
          | undefined;

      // Clear any active highlight (RCO sublayers reset + WSW tract removed).
      const clearHighlight = (): void => {
        if (rcoLayerRef) highlightedRcoLayers.forEach((p) => rcoLayerRef!.resetStyle(p));
        highlightedRcoLayers = [];
        activeShapeNames = [];
        if (wswTractLayer && map.hasLayer(wswTractLayer)) map.removeLayer(wswTractLayer);
      };

      // Highlight one or more RCO shapes by name, flying to their combined bounds.
      const highlightShapes = (rcoNames: string[], fly: boolean): void => {
        activeShapeNames = rcoNames;
        if (!rcoLayerRef || rcoNames.length === 0) return;
        const bounds = L.latLngBounds([]);
        rcoLayerRef.eachLayer((l) => {
          if (rcoNames.includes(featName(l) ?? '')) {
            const path = l as L.Path;
            path.setStyle({ weight: 3, fillOpacity: 0.18, dashArray: '' });
            path.bringToFront();
            highlightedRcoLayers.push(path);
            const b = (path as L.Polygon).getBounds();
            if (b && b.isValid()) bounds.extend(b);
          }
        });
        if (fly && bounds.isValid()) map.flyToBounds(bounds, { padding: [40, 40], maxZoom: 16 });
      };

      // Washington Square West highlights/zooms census tract 11.02, not the large
      // WSW RCO polygon. The tract layer is its own (non-RCO) overlay.
      const highlightTract = async (fly: boolean): Promise<void> => {
        if (!wswTractLayer) {
          try {
            const resp = await fetch('/data/wsw_tract.geojson');
            const gj = await resp.json();
            wswTractLayer = L.geoJSON(gj, {
              pane: 'boundaries',
              interactive: false,
              style: {
                color: '#9333EA',
                weight: 3,
                opacity: 0.95,
                fill: true,
                fillColor: '#9333EA',
                fillOpacity: 0.18,
              },
            });
          } catch (err) {
            console.error('Failed to load wsw_tract.geojson', err);
            return;
          }
        }
        wswTractLayer.addTo(map);
        if (fly) {
          const bounds = wswTractLayer.getBounds();
          if (bounds.isValid()) map.flyToBounds(bounds, { padding: [40, 40], maxZoom: 16 });
        }
      };

      // Turn the RCO overlay on if it is currently off (keeps the checkbox synced).
      const ensureRcoOn = (): void => {
        const box = document.getElementById('overlay-rcos') as HTMLInputElement | null;
        if (box && rcoLayerRef && !box.checked) {
          box.checked = true;
          rcoLayerRef.addTo(map);
        }
      };

      const setActiveTriggerEl = (el: Element | null): void => {
        document.querySelectorAll('.nbhd-trigger').forEach((b) => {
          b.classList.toggle('is-active', b === el);
        });
      };

      function renderCard(name: string, activeEl: Element | null): void {
        if (!cardEl || !demographics[name]) return;
        activeNbhd = name;
        cardEl.innerHTML = buildCardHtml(name);
        cardEl.style.display = 'block';
        setActiveTriggerEl(activeEl);
      }

      function closeCard(): void {
        if (cardEl) cardEl.style.display = 'none';
        activeNbhd = null;
        setActiveTriggerEl(null);
        clearHighlight();
        // Return the visitor to wherever they were before exploring a neighborhood.
        if (preCardView) {
          map.flyTo(preCardView.center, preCardView.zoom);
          preCardView = null;
        }
      }

      // Shared selection path. Highlights ALL shapes the card covers (so the
      // Passyunk Square card lights both the Passyunk Square and EPX shapes),
      // or the WSW tract. `fly`/`ensureOn` differ for sidebar vs map clicks.
      function selectNeighborhood(
        card: string,
        activeEl: Element | null,
        opts: { fly: boolean; ensureOn: boolean },
      ): void {
        if (!demographics[card]) return;
        // Capture the current view to restore on close — but only when opening
        // fresh (card not already up), so swapping neighborhoods doesn't lose the
        // original framing. Only when we actually fly.
        const cardOpen = cardEl?.style.display === 'block';
        if (opts.fly && !cardOpen) {
          preCardView = { center: map.getCenter(), zoom: map.getZoom() };
        }
        renderCard(card, activeEl);
        clearHighlight();
        if (opts.ensureOn) ensureRcoOn();
        if (TRACT_CARDS.has(card)) {
          void highlightTract(opts.fly);
          return;
        }
        const shapes = NBHD_TO_SHAPES[card] || [];
        if (shapes.length) highlightShapes(shapes, opts.fly);
      }

      // Map shape click: open the card and highlight in place (no fly), marking
      // the clicked shape's sidebar row active.
      function openFromMapShape(rcoName: string): void {
        const card = RCO_TO_NBHD[rcoName];
        if (!card) return;
        const btn = document.querySelector(`.nbhd-trigger[data-shape="${rcoName}"]`);
        selectNeighborhood(card, btn, { fly: false, ensureOn: false });
      }

      // Sidebar trigger: open the card, turn RCO on, fly to + highlight the
      // shape(s) or the WSW tract. Pennsport (no shape) opens the card only.
      document.getElementById('nbhd-trigger-list')?.addEventListener('click', (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.nbhd-trigger');
        if (!btn || !btn.dataset.nbhd) return;
        selectNeighborhood(btn.dataset.nbhd, btn, { fly: true, ensureOn: true });
      });

      // ---- BID layer: 2px teal outline, very light fill, permanent labels ----
      try {
        const resp = await fetch('/data/bids.geojson');
        const gj = await resp.json();
        bidLayerRef = L.geoJSON(gj, {
          pane: 'boundaries',
          interactive: false, // labels carry the meaning; never grab clicks
          style: () => ({
            color: '#0e7490',
            weight: 2,
            opacity: 0.9,
            fill: true,
            fillColor: '#0e7490',
            fillOpacity: 0.08,
          }),
          onEachFeature: (feature, layer) => {
            const name = (feature.properties as { name?: string })?.name;
            if (name) {
              layer.bindTooltip(name, {
                permanent: true,
                direction: 'center',
                className: 'bid-label',
              });
            }
          },
        });
      } catch (err) {
        console.error('Failed to load bids.geojson', err);
      }

      // ---- RCO layer: thin dashed amber outline, name on hover ----
      try {
        const resp = await fetch('/data/rcos.geojson');
        const gj = await resp.json();
        // South Street RCOs get a distinct magenta-purple (#9333EA) — kept clear
        // of the muted #7B3F99 South Street centerline so the two don't blend.
        // East Passyunk RCOs keep the amber.
        const SOUTH_ST_RCOS = new Set([
          'Queen Village Neighbors Association',
          'Society Hill Civic Association',
          'Bella Vista Neighbors Association',
          'Washington Square West Civic Association',
          'South Street/Headhouse District',
        ]);
        const rcoColor = (name?: string) =>
          name && SOUTH_ST_RCOS.has(name) ? '#9333EA' : '#b45309';
        rcoLayerRef = L.geoJSON(gj, {
          pane: 'boundaries',
          style: (feature) => {
            const c = rcoColor((feature?.properties as { name?: string })?.name);
            return {
              color: c,
              weight: 1.5,
              opacity: 0.85,
              dashArray: '4 3',
              fill: true,
              fillColor: c,
              fillOpacity: 0,
              className: 'rco-shape', // CSS gives this pointer-events:auto for hover
            };
          },
          onEachFeature: (feature, layer) => {
            const name = (feature.properties as { name?: string })?.name;
            if (name) {
              // Label text matches the boundary color: purple for South Street
              // RCOs, amber (default) for East Passyunk.
              const isSouth = SOUTH_ST_RCOS.has(name);
              layer.bindTooltip(name, {
                sticky: true,
                direction: 'top',
                className: isSouth ? 'rco-label rco-label-south' : 'rco-label',
              });
            }
            // Light fill flash on hover so the hovered ring reads at a glance —
            // skipped past the block-zoom threshold (hover is disabled there) and
            // for the currently-highlighted shape (so its highlight fill stays).
            layer.on('mouseover', () => {
              if (rcoHoverDisabled() || highlightedRcoLayers.includes(layer as L.Path)) return;
              (layer as L.Path).setStyle({ fillOpacity: 0.1 });
            });
            layer.on('mouseout', () => {
              if (highlightedRcoLayers.includes(layer as L.Path)) return;
              (layer as L.Path).setStyle({ fillOpacity: 0 });
            });
            // Click opens the demographic card and highlights every shape the
            // card covers (Passyunk Square + EPX together). EPX shares the
            // Passyunk Square card; South Street/Headhouse District has no
            // record, so it stays boundary-only (no-op).
            if (name && RCO_TO_NBHD[name]) {
              layer.on('click', () => openFromMapShape(name));
            }
          },
        });
      } catch (err) {
        console.error('Failed to load rcos.geojson', err);
      }

      // ---- Base zoning: light fill colored by zoning family ----
      // Per-code colors approximating a standard Philadelphia zoning map.
      const ZONING_COLORS: Record<string, string> = {
        SPPOA: '#6BAF6B',                                   // green — recreation / open space
        CMX1: '#FCAE91', CMX2: '#FCAE91', 'CMX2.5': '#FCAE91', // salmon — low commercial mixed-use
        CMX3: '#EF3B2C', CMX4: '#EF3B2C',                   // red — mid commercial mixed-use
        CMX5: '#99000D',                                    // dark red — high commercial mixed-use
        RSA3: '#F5F0A9', RSA5: '#F5F0A9',                   // pale yellow — single-family residential
        RM1: '#FDD0A2', RM2: '#FDD0A2', RM4: '#FDD0A2',     // light orange — multi-family residential
        RMX2: '#FD8D3C', RMX3: '#FD8D3C',                   // orange — residential mixed-use
        CA1: '#9E9AC8', CA2: '#9E9AC8',                     // muted purple — auto-oriented commercial
        I2: '#999999', ICMX: '#999999', IP: '#999999', IRMX: '#999999', // gray — industrial
      };
      // Legend groupings (family label + the codes that map to each color).
      const ZONING_FAMILIES: { name: string; codes: string; color: string }[] = [
        { name: 'Open space', codes: 'SPPOA', color: '#6BAF6B' },
        { name: 'Commercial mixed-use (low)', codes: 'CMX-1/2/2.5', color: '#FCAE91' },
        { name: 'Commercial mixed-use (mid)', codes: 'CMX-3/4', color: '#EF3B2C' },
        { name: 'Commercial mixed-use (high)', codes: 'CMX-5', color: '#99000D' },
        { name: 'Single-family residential', codes: 'RSA-3/5', color: '#F5F0A9' },
        { name: 'Multi-family residential', codes: 'RM-1/2/4', color: '#FDD0A2' },
        { name: 'Residential mixed-use', codes: 'RMX-2/3', color: '#FD8D3C' },
        { name: 'Auto-oriented commercial', codes: 'CA-1/2', color: '#9E9AC8' },
        { name: 'Industrial', codes: 'I-2 / ICMX / IP / IRMX', color: '#999999' },
      ];
      try {
        const resp = await fetch('/data/zoning_base.geojson');
        const gj = await resp.json();
        zoningLayerRef = L.geoJSON(gj, {
          pane: 'zoning',
          interactive: false, // pure backdrop — never intercept clicks
          style: (feature) => {
            const code = (feature?.properties as { code?: string })?.code ?? '';
            return {
              stroke: false,
              fill: true,
              fillColor: ZONING_COLORS[code] || '#cccccc',
              fillOpacity: 0.28,
            };
          },
        });
      } catch (err) {
        console.error('Failed to load zoning_base.geojson', err);
      }

      // Legend control — only on the map while base zoning is on.
      const zoningLegend = new L.Control({ position: 'bottomleft' });
      zoningLegend.onAdd = () => {
        const div = L.DomUtil.create('div', 'zoning-legend');
        div.innerHTML =
          '<p class="zoning-legend-title">Base zoning</p>' +
          ZONING_FAMILIES.map(
            (f) =>
              `<div class="zoning-legend-row">` +
              `<span class="zoning-legend-swatch" style="background:${f.color}"></span>` +
              `<span><span class="zoning-legend-name">${f.name}</span> ` +
              `<span class="zoning-legend-codes">${f.codes}</span></span>` +
              `</div>`,
          ).join('');
        return div;
      };

      // ================= Density score layer (South Street only) =================
      // Teal density ramp, light (low) -> dark (high), matching the legend.
      // Range tracks the 15-tract set (low tract 1.01 clipped to the circle,
      // high tract 11.01).
      const DENS_LOW = 19000, DENS_HIGH = 66000;
      const LO_RGB = [0xd7, 0xf0, 0xee], HI_RGB = [0x0d, 0x4d, 0x4a];
      const densityColor = (d: number): string => {
        const t = Math.max(0, Math.min(1, (d - DENS_LOW) / (DENS_HIGH - DENS_LOW)));
        const c = LO_RGB.map((lo, i) => Math.round(lo + (HI_RGB[i] - lo) * t));
        return `rgb(${c[0]}, ${c[1]}, ${c[2]})`;
      };

      const RETAIL_SQFT = 300000;   // estimated sq ft of corridor retail (denominator)
      const BENCHMARK = 400;        // residents per 2,000 sq ft target
      const PER = 2000;
      // Three-quarter-mile (15-min) circle catchment total = Σ full pop across the
      // 15 overlapping tracts (verified = 46,201).
      const CATCHMENT_TOTAL = 46201;
      // Residents needed to hit the 400 benchmark (slider runs 0–20,000, enough
      // to drag past critical mass).
      const residentsForBench = Math.ceil((BENCHMARK * RETAIL_SQFT) / PER); // 60,000
      const SLIDER_MAX = 20000;

      // Catchment ring (dashed purple, no fill) + its one-time label.
      let ringLabelMarker: L.Marker | null = null;
      try {
        const resp = await fetch('/data/catchment_southst.geojson');
        const gj = await resp.json();
        ringLayerRef = L.geoJSON(gj, {
          pane: 'boundaries',
          interactive: false,
          style: { color: '#6d28d9', weight: 2, opacity: 0.9, dashArray: '6 5', fill: false },
        });
        const rb = ringLayerRef.getBounds();
        if (rb.isValid()) {
          const north = L.latLng(rb.getNorth(), (rb.getWest() + rb.getEast()) / 2);
          ringLabelMarker = L.marker(north, {
            interactive: false,
            icon: L.divIcon({ className: 'ring-label', html: '¾-mile walk · 15 min', iconSize: null }),
          });
        }
      } catch (err) {
        console.error('Failed to load catchment_southst.geojson', err);
      }

      // Choropleth, colored by per-tract density (people / sq mi).
      try {
        const resp = await fetch('/data/tracts_density_southst.geojson');
        const gj = await resp.json();
        densityLayerRef = L.geoJSON(gj, {
          pane: 'density',
          interactive: false, // pure backdrop — dots stay clickable
          style: (feature) => ({
            stroke: true,
            color: '#ffffff',
            weight: 0.8,
            fill: true,
            fillColor: densityColor((feature?.properties as { density?: number })?.density ?? DENS_LOW),
            fillOpacity: 0.82,
          }),
        });
      } catch (err) {
        console.error('Failed to load tracts_density_southst.geojson', err);
      }

      // Critical-mass panel (top-left so it never overlaps the top-right card).
      const fmtR = (n: number) => Math.round(n).toLocaleString('en-US');
      const densityPanel = new L.Control({ position: 'topleft' });
      densityPanel.onAdd = () => {
        const div = L.DomUtil.create('div', 'density-panel');
        L.DomEvent.disableClickPropagation(div);
        L.DomEvent.disableScrollPropagation(div);
        div.innerHTML =
          `<h4 class="density-panel-title">15-minute walk catchment</h4>` +
          `<p class="density-panel-row"><b>${fmtR(CATCHMENT_TOTAL)}</b> residents in the ¾-mi ring</p>` +
          `<p class="density-panel-row">~<b>${fmtR(RETAIL_SQFT)}</b> sq ft of retail <span class="density-est">(est.)</span></p>` +
          `<div class="density-ratio">` +
            `<div class="density-ratio-head"><b id="dp-ratio">—</b> residents per 2,000 sq ft <span class="density-est">(est.)</span></div>` +
            `<div class="density-bar"><div class="density-bar-fill" id="dp-bar"></div></div>` +
            `<div class="density-ratio-label" id="dp-label">—</div>` +
          `</div>` +
          `<label class="density-slider-label">Add residents to the ring: <b id="dp-added">0</b></label>` +
          `<input type="range" id="dp-slider" min="0" max="${SLIDER_MAX}" step="500" value="0">` +
          `<p class="density-hint" id="dp-hint">—</p>` +
          `<div class="density-legend">` +
            `<span class="density-legend-cap">Resident density (per sq mi)</span>` +
            `<div class="density-legend-bar"></div>` +
            `<div class="density-legend-ends"><span>19k</span><span>66k</span></div>` +
          `</div>` +
          `<p class="density-note">Catchment: census tracts overlapping the corridor. Retail floor area is an estimate.</p>`;
        return div;
      };

      // Live recompute of the ratio bar from the slider.
      const updateRatioUI = (added: number): void => {
        const ratioEl = document.getElementById('dp-ratio');
        const barEl = document.getElementById('dp-bar');
        const labelEl = document.getElementById('dp-label');
        const hintEl = document.getElementById('dp-hint');
        const addedEl = document.getElementById('dp-added');
        if (!ratioEl || !barEl || !labelEl || !hintEl || !addedEl) return;
        const total = CATCHMENT_TOTAL + added;
        const ratio = (total / RETAIL_SQFT) * PER;
        ratioEl.textContent = String(Math.round(ratio));
        addedEl.textContent = fmtR(added);
        barEl.style.width = Math.min(100, (ratio / BENCHMARK) * 100) + '%';
        if (ratio >= BENCHMARK) {
          barEl.classList.add('is-reached');
          labelEl.textContent = 'critical mass reached';
          labelEl.classList.add('is-reached');
          hintEl.textContent = '';
        } else {
          barEl.classList.remove('is-reached');
          labelEl.classList.remove('is-reached');
          labelEl.textContent = Math.round((1 - ratio / BENCHMARK) * 100) + '% below the 400 benchmark';
          const need = residentsForBench - total;
          hintEl.textContent = `needs about ${fmtR(need)} more to reach critical mass`;
        }
      };

      // BID permanent labels hide while a single corridor is selected; they show
      // only under "All Corridors". The outlines themselves are never affected.
      const updateBidLabelVisibility = () => {
        map.getContainer().classList.toggle(
          'bid-labels-hidden',
          filterState.corridor !== 'all',
        );
      };
      // Re-evaluate on every filter change (corridor switches fire subscribers).
      subscribe(updateBidLabelVisibility);

      // Suppress RCO hover labels once zoomed to block level (see threshold).
      const updateRcoHoverForZoom = () => {
        map.getContainer().classList.toggle('rco-hover-off', rcoHoverDisabled());
      };
      map.on('zoomend', updateRcoHoverForZoom);
      updateRcoHoverForZoom();

      // ---- Wire sidebar checkboxes ----
      // BID defaults ON; RCO defaults OFF (toggle adds it on demand).
      const bidBox = document.getElementById('overlay-bids') as HTMLInputElement | null;
      const rcoBox = document.getElementById('overlay-rcos') as HTMLInputElement | null;
      if (bidBox && bidLayerRef) {
        bidBox.checked = true;
        bidLayerRef.addTo(map);
        bidBox.addEventListener('change', () => {
          if (!bidLayerRef) return;
          if (bidBox.checked) bidLayerRef.addTo(map);
          else map.removeLayer(bidLayerRef);
        });
      }
      if (rcoBox && rcoLayerRef) {
        rcoBox.checked = false; // default OFF — not added to the map on load
        rcoBox.addEventListener('change', () => {
          if (!rcoLayerRef) return;
          if (rcoBox.checked) {
            rcoLayerRef.addTo(map);
            // Re-apply the highlight for the open card's shape(s), if any.
            if (activeShapeNames.length) highlightShapes(activeShapeNames, false);
          } else {
            highlightedRcoLayers = []; // layers leaving the map; drop stale refs
            map.removeLayer(rcoLayerRef);
          }
        });
      }
      const zoningBox = document.getElementById('overlay-zoning') as HTMLInputElement | null;
      if (zoningBox && zoningLayerRef) {
        zoningBox.checked = false; // default OFF
        zoningBox.addEventListener('change', () => {
          if (!zoningLayerRef) return;
          if (zoningBox.checked) {
            zoningLayerRef.addTo(map);
            zoningLegend.addTo(map);   // legend appears only with the layer
          } else {
            map.removeLayer(zoningLayerRef);
            zoningLegend.remove();
          }
        });
      }
      // Density score: choropleth + ring + panel toggle together (default OFF).
      const showDensity = (): void => {
        if (densityLayerRef) densityLayerRef.addTo(map);
        if (ringLayerRef) ringLayerRef.addTo(map);
        if (ringLabelMarker) ringLabelMarker.addTo(map);
        densityPanel.addTo(map);
        updateRatioUI(0);
        const slider = document.getElementById('dp-slider') as HTMLInputElement | null;
        slider?.addEventListener('input', () => updateRatioUI(Number(slider.value)));
      };
      const hideDensity = (): void => {
        if (densityLayerRef) map.removeLayer(densityLayerRef);
        if (ringLayerRef) map.removeLayer(ringLayerRef);
        if (ringLabelMarker) map.removeLayer(ringLabelMarker);
        densityPanel.remove();
      };
      const densityBox = document.getElementById('overlay-density') as HTMLInputElement | null;
      if (densityBox) {
        densityBox.checked = false;
        densityBox.addEventListener('change', () => {
          if (densityBox.checked) showDensity();
          else hideDensity();
        });
      }

      // Density is a South Street measure: disable + gray the toggle on East
      // Passyunk, and hide the layer if it was on. Re-enable on All / South St.
      const updateDensityAvailability = (): void => {
        if (!densityBox) return;
        const isEP = filterState.corridor === 'east-passyunk';
        densityBox.disabled = isEP;
        densityBox.closest('.filter-group')?.classList.toggle('is-disabled', isEP);
        if (isEP && densityBox.checked) {
          densityBox.checked = false;
          hideDensity();
        }
      };
      subscribe(updateDensityAvailability);
      updateDensityAvailability();

      // Apply initial label visibility for the default corridor state.
      updateBidLabelVisibility();
    }

    async function initMap() {
      const map = L.map('map', {
        center: [39.938, -75.155],
        zoom: 16,
        maxZoom: 19,
        zoomControl: true,
      });
      // Capture the framing the visitor sees on arrival so "All Corridors"
      // can fly back to it later.
      mapRef = map;
      initialView = { center: map.getCenter(), zoom: map.getZoom() };

      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19,
      }).addTo(map);

      // Dedicated pane for BID/RCO boundary overlays. z-index 350 sits above the
      // tile pane (200) but below the default overlayPane (400) where the street
      // lines and parcel circleMarkers render — so boundaries always draw beneath
      // the dots and the dots stay on top and clickable.
      map.createPane('boundaries');
      const boundaryPane = map.getPane('boundaries');
      if (boundaryPane) boundaryPane.style.zIndex = '350';

      // Base-zoning fill sits in its own pane at z-index 340 — above the tiles
      // (200) but below the boundary outlines (350) and the parcel dots /
      // streets in overlayPane (400), so dots and BID/RCO outlines stay on top.
      map.createPane('zoning');
      const zoningPane = map.getPane('zoning');
      if (zoningPane) zoningPane.style.zIndex = '340';

      // Density choropleth sits lowest of the overlays (z-index 330) — below the
      // zoning fill, the boundary outlines, and the dots. Its catchment ring
      // renders in the 'boundaries' pane (350), above the choropleth, below dots.
      map.createPane('density');
      const densityPane = map.getPane('density');
      if (densityPane) densityPane.style.zIndex = '330';

      // Streets layer — render below parcels
      try {
        const streetsResp = await fetch('/data/streets.geojson');
        const streetsGj = await streetsResp.json();
        streetsLayerRef = L.geoJSON(streetsGj, {
          style: (feature) => {
            const key = feature?.properties?.corridor as string | undefined;
            const base = (key && STREET_STYLES[key]) || { color: '#888', weight: 3 };
            return {
              color: base.color,
              weight: base.weight,
              opacity: 0.4,
              className: 'corridor-line',
            };
          },
        }).addTo(map);
        // Stash bounds per corridor for the corridor-segmented fly-to behavior.
        for (const f of streetsGj.features) {
          const key = f?.properties?.corridor as string | undefined;
          if (key === 'south_street' || key === 'east_passyunk') {
            const tempLayer = L.geoJSON(f);
            const b = tempLayer.getBounds();
            if (b.isValid()) corridorBounds[key] = b;
          }
        }
        // Build a combined bounds box covering both corridors. Used by the
        // "All Corridors" fly-target and as the initial map framing.
        const ss = corridorBounds.south_street;
        const ep = corridorBounds.east_passyunk;
        if (ss && ep) {
          combinedCorridorBounds = L.latLngBounds(ss.getSouthWest(), ss.getNorthEast());
          combinedCorridorBounds.extend(ep);
        } else if (ss) {
          combinedCorridorBounds = ss;
        } else if (ep) {
          combinedCorridorBounds = ep;
        }
        // Initial framing: fit both corridors centered between them. Overrides
        // the static L.map center/zoom set above. Then re-capture initialView
        // so the existing flyTo('all') logic falls back to this same framing.
        if (combinedCorridorBounds && combinedCorridorBounds.isValid()) {
          map.fitBounds(combinedCorridorBounds, { padding: [60, 60] });
          initialView = { center: map.getCenter(), zoom: map.getZoom() };
        }
      } catch (err) {
        console.error('Failed to load streets.geojson', err);
      }

      // Parcels layer — split so non-commercial dots can be toggled by zoom
      try {
        const parcelsResp = await fetch('/data/parcels.geojson');
        const parcelsGj = await parcelsResp.json();

        const bindPopupTo = (feature: GeoJSON.Feature, layer: L.Layer) => {
          layer.bindPopup(buildPopup(feature.properties as ParcelProps), {
            maxWidth: 280,
          });
        };

        // Commercial + vacant dots: always visible at full opacity
        L.geoJSON(parcelsGj, {
          filter: (feature) =>
            feature.properties?.vacancy_state !== 'non_commercial',
          pointToLayer: (feature, latlng) => {
            const props = feature.properties as ParcelProps;
            const state = props.vacancy_state;
            const marker = L.circleMarker(latlng, {
              radius: 7,
              fillColor: VACANCY_COLORS[state] || '#888',
              color: '#ffffff',
              weight: 1,
              opacity: 1,
              fillOpacity: 0.9,
            });
            markerIndex.set(props.id, { layer: marker, props });
            return marker;
          },
          onEachFeature: bindPopupTo,
        }).addTo(map);

        // Non-commercial dots: created standalone (not added to map at init);
        // the subscribe path manages add/remove per marker based on
        // shouldShowNonCommercialLayer() + matchesAll() / lens scope.
        L.geoJSON(parcelsGj, {
          filter: (feature) =>
            feature.properties?.vacancy_state === 'non_commercial',
          pointToLayer: (feature, latlng) => {
            const props = feature.properties as ParcelProps;
            const marker = L.circleMarker(latlng, {
              radius: 7,
              fillColor: VACANCY_COLORS.non_commercial,
              color: '#ffffff',
              weight: 1,
              opacity: 0.4,
              fillOpacity: 0.35,
            });
            nonCommercialMarkerIndex.set(props.id, { layer: marker, props });
            return marker;
          },
          onEachFeature: bindPopupTo,
        });
        // No .addTo(map) — markers are managed individually below.

        // Zoom change feeds back into subscribers so non-commercial visibility
        // recomputes alongside everything else (chip counts, etc.).
        map.on('zoomend', () => {
          subscribers.forEach((fn) => fn());
        });

        // -------------------- Wire Corridor section --------------------
        wireCorridorSegmented();
        wireStickyCorridorObserver();

        // -------------------- Wire Map overlays section ----------------
        await initBoundaryOverlays(map);

        // -------------------- Wire Business mix section --------------------
        parcelsGjRef = parcelsGj;
        buildSegmentMap(parcelsGj);
        buildBlockStats(parcelsGj);                          // ribbon data (Sub-phase A)
        recomputeChipCounts();                                // initial counts (scope-aware)
        renderBusinessMixUI();
        wireBusinessMixSidebar();
        renderBuildingMixUI();                                // Phase 5: Building mix chips + sliders
        wireBuildingMixSidebar();
        renderRibbon();                                       // initial paint (Sub-phase B)
        wireRibbonControls();                                 // metric selector + block clicks
        wireCorridorReset();                                  // Reset link in Corridor section header
        updateRibbonCorridorDimming();                        // initial dimming state
        syncRibbonToCorridor();                               // initial collapse (default corridor = All)

        // -------------------- Subscribe path --------------------
        subscribe(() => {
          recomputeChipCounts();
          updateAllCountSpans();
          if (filterState.culturalLens) {
            renderLensMode();
          } else {
            renderNormalMode();
          }
          updateSidebarChrome();
          updateCorridorCounter();
        });

        // Initial chrome update (badge / reset visibility for default state).
        updateAllCountSpans();
        updateSidebarChrome();
        updateCorridorCounter();
        // Run subscribers once to perform the initial render (which also adds
        // markers to the map based on current visibility logic).
        subscribers.forEach((fn) => fn());

        // Expose for manual console testing.
        (window as unknown as Record<string, unknown>).__filterState = filterState;
        (window as unknown as Record<string, unknown>).__setFilterState = setFilterState;
        (window as unknown as Record<string, unknown>).__matchesAll = matchesAll;
        (window as unknown as Record<string, unknown>).__blockStats = blockStats;
      } catch (err) {
        console.error('Failed to load parcels.geojson', err);
      }
    }

    initMap();
  </script>
</Layout>
