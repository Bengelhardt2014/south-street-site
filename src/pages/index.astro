---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Map — Saving South Street">
  <section>
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900">South Street &amp; East Passyunk Avenue</h1>
    <p class="mt-3 max-w-2xl text-stone-700">
      An interactive map of the two study corridors, with filterable dots representing parcels and businesses.
      Use the map to compare land use, occupancy, and business mix across the two corridors.
    </p>

    <div class="mt-8 flex h-[28rem] items-center justify-center rounded-lg border border-dashed border-stone-300 bg-white text-stone-500">
      Interactive map will go here.
    </div>
  </section>
</Layout>
