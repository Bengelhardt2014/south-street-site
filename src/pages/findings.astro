    color: #a8a29e; /* stone-400 */
  }
  .finding-source--table {
    margin: 0.5rem 0 0;
    max-width: 60ch;
    line-height: 1.4;
  }

  /* Finding 4 comparison table (accessible). Scrolls on very narrow screens. */
  .finding-table-wrap {
    margin-top: 1.25rem;
    overflow-x: auto;
  }
