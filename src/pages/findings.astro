    margin: 0.5rem 0 0;
    max-width: 28ch;
    font-size: 1.6rem;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #1c1917; /* stone-900 */
  }

  /* Section rhythm: a thin rule sets each section apart, like the History page. */
  .finding-section {
    margin-top: 2.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid #e7e5e4; /* stone-200 */
  }

  .finding-kicker {
    margin: 0 0 0.2rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #78716c; /* stone-500 */
  }

