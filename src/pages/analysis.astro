---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Policy Analysis — Saving South Street">
  <section class="max-w-3xl">
    <h1 class="text-3xl font-semibold tracking-tight text-stone-900">Policy Analysis</h1>
    <p class="mt-3 text-stone-700">
      The thesis findings in long form: the case for a Pennsylvania Creative District designation for South Street,
      paired with a local Creative Corridor Overlay. This page will include section headers, comparison tables
      between South Street and East Passyunk Avenue, and embedded chart images.
    </p>
  </section>
</Layout>
