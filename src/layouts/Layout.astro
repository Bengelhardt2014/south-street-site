---
import '../styles/global.css';

interface Props {
  title?: string;
  fullBleed?: boolean;
}

const { title = 'Saving South Street', fullBleed = false } = Astro.props;

const navLinks = [
  { href: '/summary', label: 'Summary' },
  { href: '/map', label: 'Map' },
  { href: '/history', label: 'History' },
  { href: '/findings', label: 'Findings' },
  { href: '/analysis', label: 'Policy Analysis' },
  { href: '/about', label: 'About' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Bebas+Neue&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased">
    <header id="site-header" class="bg-stone-900 text-stone-50">
      <div class="px-6 py-3">
        <div class="flex items-center justify-between gap-3">
          <a
            href="/"
            class="wordmark text-[1.5rem] text-stone-50 hover:text-stone-50"
            style="font-family: 'Bebas Neue', 'Anton', sans-serif;"
          >
            Saving South Street
          </a>

          <!-- Desktop horizontal nav (unchanged at md and up). -->
          <nav class="hidden md:block">
            <ul class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
              {navLinks.map(({ href, label }) => {
                const isActive = currentPath === href;
                return (
                  <li>
                    <a
                      href={href}
                      class={`block rounded px-3 py-1.5 transition-colors ${
                        isActive
                          ? 'bg-stone-800 font-medium text-stone-50'
                          : 'text-stone-300 hover:text-stone-50'
                      }`}
                    >
                      {label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </nav>

          <!-- Mobile menu button (below md only). -->
          <button
            id="nav-toggle"
            type="button"
            class="-mr-1.5 inline-flex items-center justify-center rounded p-1.5 text-stone-200 hover:text-stone-50 md:hidden"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg class="nav-icon-open h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="3" y1="6" x2="21" y2="6" />
              <line x1="3" y1="12" x2="21" y2="12" />
              <line x1="3" y1="18" x2="21" y2="18" />
            </svg>
            <svg class="nav-icon-close hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="5" y1="5" x2="19" y2="19" />
              <line x1="19" y1="5" x2="5" y2="19" />
            </svg>
          </button>
        </div>

        <!-- Mobile dropdown menu (below md only). -->
        <nav id="mobile-nav" class="mt-3 hidden md:hidden" aria-label="Site">
          <ul class="flex flex-col gap-1 text-sm">
            {navLinks.map(({ href, label }) => {
              const isActive = currentPath === href;
              return (
                <li>
                  <a
                    href={href}
                    aria-current={isActive ? 'page' : undefined}
                    class={`block rounded px-3 py-2 transition-colors ${
                      isActive
                        ? 'bg-stone-800 font-medium text-stone-50'
                        : 'text-stone-300 hover:bg-stone-800 hover:text-stone-50'
                    }`}
                  >
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </div>
      <div class="h-0.5 w-full bg-[#8b1a1a]"></div>
    </header>

    {fullBleed ? (
      <slot />
    ) : (
      <>
        <main class="mx-auto max-w-6xl px-6 py-10">
          <slot />
        </main>

        <footer class="mt-16 border-t border-stone-200 bg-white">
          <div class="mx-auto max-w-6xl px-6 py-6 text-xs text-stone-500">
            Saving South Street &middot; An urban planning thesis project
          </div>
        </footer>
      </>
    )}

    <!-- Mobile nav open/close toggle. -->
    <script>
      const navToggle = document.getElementById('nav-toggle');
      const mobileNav = document.getElementById('mobile-nav');
      if (navToggle && mobileNav) {
        const iconOpen = navToggle.querySelector('.nav-icon-open');
        const iconClose = navToggle.querySelector('.nav-icon-close');
        const setOpen = (open: boolean) => {
          mobileNav.classList.toggle('hidden', !open);
          navToggle.setAttribute('aria-expanded', String(open));
          navToggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
          iconOpen?.classList.toggle('hidden', open);
          iconClose?.classList.toggle('hidden', !open);
        };
        navToggle.addEventListener('click', () =>
          setOpen(mobileNav.classList.contains('hidden')),
        );
        mobileNav.querySelectorAll('a').forEach((a) =>
          a.addEventListener('click', () => setOpen(false)),
        );
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') setOpen(false);
        });
      }
    </script>
  </body>
</html>
