---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Saving South Street' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Map' },
  { href: '/timeline', label: 'Timeline' },
  { href: '/presentation', label: 'Presentation' },
  { href: '/analysis', label: 'Policy Analysis' },
  { href: '/data', label: 'Data' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-stone-900 antialiased">
    <header class="border-b border-stone-200 bg-white">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
        <a href="/" class="text-lg font-semibold tracking-tight text-stone-900 hover:text-stone-700">
          Saving South Street
        </a>
        <nav>
          <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm">
            {navLinks.map(({ href, label }) => {
              const isActive = currentPath === href;
              return (
                <li>
                  <a
                    href={href}
                    class={`transition-colors ${
                      isActive
                        ? 'font-medium text-stone-900 underline underline-offset-4'
                        : 'text-stone-600 hover:text-stone-900'
                    }`}
                  >
                    {label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-10">
      <slot />
    </main>

    <footer class="mt-16 border-t border-stone-200 bg-white">
      <div class="mx-auto max-w-6xl px-6 py-6 text-xs text-stone-500">
        Saving South Street &middot; An urban planning thesis project
      </div>
    </footer>
  </body>
</html>
